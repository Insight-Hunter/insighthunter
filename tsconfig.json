{
    "compilerOptions": {
     "rootDir": "./",
      "target": "ES2022",
      "module": "CommonJS",
      "moduleResolution": "bundler",
      "lib":         ["ES2022"],
      "types":     [" "],
      "strict":      true,
      "noEmit":      true,
      "skipLibCheck": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
  }
  