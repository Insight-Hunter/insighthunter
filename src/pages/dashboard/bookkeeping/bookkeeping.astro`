---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import BookkeepingApp from '../../components/dashboard/bookkeeping/BookkeepingApp.svelte';
---

<DashboardLayout title="Bookkeeping" activeNav="bookkeeping">
  <div class="bookkeeping-page">
    <header class="page-header">
      <div>
        <h1>Bookkeeping</h1>
        <p class="subtitle">Double-entry ledger, journal entries &amp; financial reports</p>
      </div>
    </header>

    <BookkeepingApp client:load />
  </div>
</DashboardLayout>

<style>
  .bookkeeping-page {
    padding: var(--space-6);
    max-width: 1400px;
    margin: 0 auto;
  }
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-6);
  }
  h1 {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-taupe-900);
    margin: 0 0 var(--space-1);
  }
  .subtitle {
    color: var(--color-taupe-500);
    font-size: var(--text-sm);
    margin: 0;
  }
</style>
