{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build":  { "dependsOn": ["^build"], "outputs": ["dist/**", ".astro/**"] },
    "test":   { "dependsOn": ["^build"] },
    "deploy": { "dependsOn": ["build"], "cache": false },
    "dev":    { "persistent": true, "cache": false }
  }
}
