{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "lint": { "outputs": [] },
    "typecheck": { "dependsOn": ["^typecheck"], "outputs": [] },
    "test": { "dependsOn": ["lint", "typecheck", "^test"], "outputs": [] },
    "build": { "dependsOn": ["test", "^build"], "outputs": ["dist/**"] },
    "dev": { "cache": false, "persistent": true }
  }
}
