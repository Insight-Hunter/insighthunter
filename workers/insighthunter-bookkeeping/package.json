{
  "name": "insighthunter-bookkeeping",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/worker.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply insighthunter-bookkeeping",
    "db:seed": "wrangler d1 execute insighthunter-bookkeeping --file src/backend/db/seed.sql"
  },
  "dependencies": {
    "@ih/tier-config": "*",
    "@ih/types": "*",
    "hono": "^4.7.4",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250317.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.76.0"
  }
}
