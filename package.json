{
  "name": "insighthunter",
  "private": true,
  "workspaces": [
    "packages/@ih/types",
    "packages/@ih/tier-config",
    "packages/@ih/auth-client",
    "apps/insighthunter-auth",
    "apps/insighthunter-dispatch",
    "apps/insighthunter-bookkeeping",
    "apps/insighthunter-bizforma",
    "apps/insighthunter-pbx",
    "apps/insighthunter-payroll",
    "apps/insighthunter-ai",
    "apps/insighthunter-main",
    "workers-for-platforms/tenant-base-worker"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "deploy": "bash scripts/deploy.sh",
    "provision": "bash scripts/provision.sh",
    "migrate": "bash scripts/migrate.sh",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "openssl": "^2.0.0"
  }
}
