{
    "mcpServers": {
      "perplexity": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "perplexity-mcp"],
        "env": {
          "PERPLEXITY_API_KEY": "${env:PERPLEXITY_API_KEY}"
        }
      },
      "firebase": {
        "command": "npx",
        "args": [
            "-y",
            "firebase-tools@latest",
            "experimental:mcp"
        ]
      }
    }
}
