---
import MarketingLayout from './MarketingLayout.astro';
import Sidebar from '../components/dashboard/Sidebar.svelte';
import TopBar from '../components/dashboard/TopBar.svelte';

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect(`https://auth.insighthunter.app/login?redirect_uri=${encodeURIComponent(Astro.url.href)}`);
}

export interface Props { title: string; }
const { title } = Astro.props;
---
<MarketingLayout title={title}>
  <div class="dashboard-shell">
    <Sidebar client:load session={session} />
    <div class="main-content">
      <TopBar client:load session={session} />
      <main class="page-content">
        <slot />
      </main>
    </div>
  </div>
</MarketingLayout>

<style>
.dashboard-shell {
  display: flex;
  min-height: 100vh;
  background: var(--bg);
}
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.page-content {
  flex: 1;
  padding: 24px;
  overflow-y: auto;
}
</style>
