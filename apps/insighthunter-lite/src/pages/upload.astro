---
// apps/insighthunter-lite/src/pages/upload.astro
import DashboardLayout from '../layouts/DashboardLayout.astro';
import CSVUploader from '../components/islands/CSVUploader.svelte';
---

<DashboardLayout title="Upload CSV — InsightHunter Lite">
  <div class="upload-wrapper">
    <header>
      <h1>Upload Transaction Data</h1>
      <p>
        Upload a CSV file with your bank transactions. The file should contain at least a
        <code>Date</code> and <code>Amount</code> column.
        <a href="/public/sample-transactions.csv" download>Download a sample CSV</a> to see the required format.
      </p>
    </header>
    <CSVUploader client:load />
  </div>
</DashboardLayout>

<style>
  .upload-wrapper { max-width: 720px; margin: 0 auto; padding: 2rem 1rem; }
  header          { margin-bottom: 2rem; }
  h1              { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
  p               { color: #6b7280; line-height: 1.6; }
  code            { background: #f3f4f6; padding: 0.1em 0.4em; border-radius: 4px; font-size: 0.875em; }
  a               { color: #007aff; }
</style>
