{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client", "react", "react-dom"],
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "include": ["src/frontend/**/*.ts", "src/frontend/**/*.tsx"],
  "exclude": ["src/backend"]
}
