{
    "name": "insighthunter-main",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
      "dev":     "astro dev",
      "start":   "astro dev",
      "build":   "astro check && astro build",
      "preview": "astro preview",
      "check":   "astro check",
      "typecheck": "tsc --noEmit",
      "lint":    "eslint src --ext .ts,.astro,.svelte",
      "format":  "prettier --write .",
      "test":    "vitest run",
      "test:watch": "vitest",
      "deploy":  "pnpm run build && wrangler pages deploy dist"
    },
  
    "dependencies": {
      "astro":               "^5.6.1",
      "@astrojs/cloudflare": "^13.1.6",
      "@astrojs/svelte":     "^8.0.0",
      "@astrojs/sitemap":    "^3.2.1",
      "@astrojs/check":      "^0.9.4",
      "svelte":              "^5.25.3",
  
      "@telnyx/webrtc":      "^2.25.11",
  
      "hono":                "^4.7.4",
      "zod":                 "^3.24.2"
    },
  
    "devDependencies": {
      "typescript":               "^5.8.2",
      "wrangler":                 "^4.4.0",
  
      "@cloudflare/workers-types": "^4.20250401.0",
  
      "sass":                     "^1.86.0",
      "autoprefixer":             "^10.4.21",
      "postcss":                  "^8.5.3",
  
      "prettier":                 "^3.5.3",
      "prettier-plugin-astro":    "^0.14.1",
      "prettier-plugin-svelte":   "^3.3.3",
  
      "eslint":                        "^9.23.0",
      "@typescript-eslint/eslint-plugin": "^8.29.0",
      "@typescript-eslint/parser":        "^8.29.0",
      "eslint-plugin-astro":             "^1.3.1",
      "eslint-plugin-svelte":            "^2.46.1",
  
      "vitest":              "^3.1.1",
      "@vitest/ui":          "^3.1.1",
  
      "vite":                "^6.2.4",
      "@sveltejs/vite-plugin-svelte": "^5.0.3"
    },
  
    "engines": {
      "node": ">=20.0.0",
      "pnpm": ">=9.0.0"
    },
  
    "packageManager": "pnpm@9.15.4"
  }
  