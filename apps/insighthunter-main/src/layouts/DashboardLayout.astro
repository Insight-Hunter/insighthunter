---
import Sidebar from '../components/dashboard/Sidebar.svelte';
import TopBar from '../components/dashboard/TopBar.svelte';

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Insight Hunter dashboard workspace.',
} = Astro.props;

const session = Astro.locals.session;
const siteName = 'Insight Hunter';

if (!session) {
  const next = encodeURIComponent(Astro.url.pathname + Astro.url.search);
  return Astro.redirect(`/auth/login?next=${next}`);
}

const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const currentOrgName =
  session?.user?.orgName ??
  session?.org?.name ??
  session?.user?.email ??
  'Workspace';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#0b1220" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&f[]=satoshi@400,500,700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <a class="skip-link" href="#dashboard-content">Skip to content</a>

    <div class="dashboard-shell">
      <aside class="dashboard-sidebar">
        <Sidebar client:load session={session} />
      </aside>

      <div class="dashboard-main">
        <header class="dashboard-topbar">
          <TopBar client:load session={session} />
        </header>

        <main id="dashboard-content" class="dashboard-content">
          <section class="dashboard-page-head">
            <div>
              <p class="dashboard-kicker">Workspace</p>
              <h1>{title}</h1>
            </div>

            <div class="dashboard-context card-lite">
              <span class="context-label">Organization</span>
              <strong>{currentOrgName}</strong>
            </div>
          </section>

          <div class="dashboard-slot">
            <slot />
          </div>
        </main>
      </div>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --app-bg: #0a101a;
    --app-bg-soft: #101826;
    --app-panel: #121c2b;
    --app-panel-alt: #172233;
    --app-border: rgba(149, 172, 201, 0.16);
    --app-border-strong: rgba(103, 197, 255, 0.32);
    --app-text: #edf4ff;
    --app-muted: #97a9c0;
    --app-subtle: #6f8198;
    --app-cyan: #68d6ff;
    --app-cyan-soft: rgba(104, 214, 255, 0.12);
    --app-gold: #eb9650;
    --app-radius-sm: 12px;
    --app-radius-md: 18px;
    --app-shadow: 0 22px 54px rgba(0, 0, 0, 0.24);

    --font-display: 'General Sans', 'Inter', sans-serif;
    --font-body: 'Satoshi', 'Inter', sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background:
      radial-gradient(circle at top left, rgba(104, 214, 255, 0.06), transparent 28%),
      linear-gradient(180deg, #0a101a 0%, #09111a 100%);
    color: var(--app-text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--app-text);
    line-height: 1.08;
  }

  p {
    margin: 0;
  }

  .skip-link {
    position: absolute;
    left: 12px;
    top: -44px;
    z-index: 999;
    padding: 10px 14px;
    border-radius: 10px;
    background: #ffffff;
    color: #09111a;
    font-weight: 700;
  }

  .skip-link:focus {
    top: 12px;
  }

  .card-lite {
    border: 1px solid var(--app-border);
    border-radius: var(--app-radius-md);
    background: linear-gradient(180deg, rgba(20, 30, 46, 0.94), rgba(15, 24, 37, 0.94));
    box-shadow: var(--app-shadow);
  }
</style>

<style>
  .dashboard-shell {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    min-height: 100vh;
    background: transparent;
  }

  .dashboard-sidebar {
    min-width: 0;
    border-right: 1px solid var(--app-border);
    background:
      linear-gradient(180deg, rgba(12, 19, 29, 0.98), rgba(10, 16, 26, 0.98));
  }

  .dashboard-main {
    min-width: 0;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
  }

  .dashboard-topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--app-border);
    background: rgba(10, 16, 26, 0.82);
    backdrop-filter: blur(16px);
  }

  .dashboard-content {
    min-width: 0;
    overflow-y: auto;
    padding: 28px;
  }

  .dashboard-page-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 24px;
  }

  .dashboard-kicker {
    margin-bottom: 8px;
    color: var(--app-cyan);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dashboard-page-head h1 {
    font-size: clamp(1.9rem, 3.2vw, 2.7rem);
    letter-spacing: -0.03em;
  }

  .dashboard-context {
    min-width: 220px;
    padding: 16px 18px;
  }

  .context-label {
    display: block;
    margin-bottom: 4px;
    color: var(--app-subtle);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dashboard-context strong {
    color: var(--app-text);
    font-size: 0.98rem;
    font-weight: 700;
  }

  .dashboard-slot {
    min-width: 0;
  }

  @media (max-width: 1100px) {
    .dashboard-shell {
      grid-template-columns: 88px minmax(0, 1fr);
    }

    .dashboard-content {
      padding: 22px;
    }
  }

  @media (max-width: 860px) {
    body {
      overflow: auto;
    }

    .dashboard-shell {
      grid-template-columns: 1fr;
      min-height: 100vh;
    }

    .dashboard-sidebar {
      border-right: none;
      border-bottom: 1px solid var(--app-border);
    }

    .dashboard-page-head {
      flex-direction: column;
      align-items: stretch;
    }

    .dashboard-context {
      min-width: 0;
    }
  }

  @media (max-width: 640px) {
    .dashboard-content {
      padding: 18px 14px 28px;
    }

    .dashboard-page-head h1 {
      font-size: clamp(1.7rem, 8vw, 2.2rem);
    }
  }
</style>
