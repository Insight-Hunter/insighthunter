---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'AI-powered financial insights for small businesses.', ogImage } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Insight Hunter</title>
  <meta name="description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:title" content={`${title} | Insight Hunter`} />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="preconnect" href="https://api.fontshare.com" />
  <link
    href="https://api.fontshare.com/v2/css?f[]=general-sans@700,400&f[]=satoshi@400,500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  :root {
    --bg: #0d0d0d;
    --bg-navy: #141522;
    --surface: #141414;
    --surface-alt: #1a1a1a;
    --card: #1c1b19;
    --gold: #C9A84C;
    --white: #FFFFFF;
    --muted: #999999;
    --font-display: 'General Sans', 'Inter', sans-serif;
    --font-body: 'Satoshi', 'Inter', sans-serif;
    --radius-card: 16px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3, h4, h5, h6 { font-family: var(--font-display); font-weight: 700; }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; }
</style>
