---
import '../styles/theme.scss';
const { title = 'InsightHunter — AI CFO for Small Business' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600&family=Source+Serif+4&display=swap" rel="stylesheet" />
</head>
<body>
<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">InsightHunter</a>
    <div class="nav__links">
      <a href="/pricing">Pricing</a>
      <a href="/about">About</a>
      <a href="/auth/login" class="btn btn--ghost">Sign in</a>
      <a href="/auth/register" class="btn btn--primary">Get started</a>
    </div>
  </div>
</nav>
<main><slot /></main>
<footer class="footer">
  <div class="footer__inner">
    <span>© 2025 InsightHunter. All rights reserved.</span>
    <nav class="footer__links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </nav>
  </div>
</footer>
</body>
</html>
<style>
  .nav { border-bottom: 1px solid var(--color-border); background: var(--color-surface); }
  .nav__inner { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-8); height: 64px; display: flex; align-items: center; justify-content: space-between; }
  .nav__logo { font-family: var(--font-display); font-size: 1.5rem; color: var(--taupe-800); text-decoration: none; font-weight: 700; }
  .nav__links { display: flex; align-items: center; gap: var(--space-6); font-size: 0.875rem; }
  .nav__links a { color: var(--color-text-muted); }
  .footer { border-top: 1px solid var(--color-border); margin-top: var(--space-16); }
  .footer__inner { max-width: 1200px; margin: 0 auto; padding: var(--space-8); display: flex; justify-content: space-between; font-size: 0.875rem; color: var(--color-text-muted); }
  .footer__links { display: flex; gap: var(--space-6); }
</style>
