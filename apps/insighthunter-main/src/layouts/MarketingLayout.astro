---
import '../styles/theme.scss';
const { title = 'InsightHunter — AI CFO for Small Business' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600&family=Source+Serif+4&display=swap" rel="stylesheet" />
</head>
<body>
<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">InsightHunter</a>
    <div class="nav__links">
      <a href="/pricing">Pricing</a>
      <a href="/about">About</a>
      <a href="/auth/login" class="btn btn--ghost">Sign in</a>
      <a href="/auth/register" class="btn btn--primary">Get started</a>
    </div>
  </div>
</nav>
<main><slot /></main>
<footer class="footer">
  <div class="footer__inner">
    <span>© 2025 InsightHunter. All rights reserved.</span>
    <nav class="footer__links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </nav>
  </div>
</footer>
</body>
</html>
