---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'Insight Hunter',
  description = 'Insight Hunter is an AI CFO platform for small businesses that need reporting, forecasting, bookkeeping, and operating visibility in one place.',
  ogImage = '/og/home.png',
  noIndex = false,
} = Astro.props;

const siteName = 'Insight Hunter';
const publicAppUrl = Astro.site?.toString() ?? 'https://insighthunter.app';
const canonicalUrl = new URL(Astro.url.pathname, publicAppUrl).toString();
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

const navLinks = [
  { href: '/#apps', label: 'Platform' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const platformLinks = [
  { href: '/bookkeeping', label: 'Bookkeeping' },
  { href: '/payroll', label: 'Payroll' },
  { href: '/bizforma', label: 'BizForma' },
  { href: '/pbx', label: 'PBX' },
  { href: '/insight-lite', label: 'Insight Lite' },
  { href: '/insight-standard', label: 'Insight Standard' },
];

const companyLinks = [
  { href: '/about', label: 'About' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/contact', label: 'Contact' },
  { href: '/kb', label: 'Knowledge Base' },
];

const accountLinks = [
  { href: '/auth/login', label: 'Sign In' },
  { href: '/auth/register', label: 'Create Account' },
  { href: '/pricing', label: 'Compare Plans' },
  { href: '/onboarding', label: 'Onboarding' },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: publicAppUrl,
  logo: `${publicAppUrl}/favicon.svg`,
  description,
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: siteName,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonicalUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, publicAppUrl).toString()} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, publicAppUrl).toString()} />

    <meta name="theme-color" content="#07111f" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&f[]=satoshi@400,500,700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  </head>

  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="nav" id="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="Insight Hunter home">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.22" />
            <path d="M9 20.5L14 15.5L17.5 18L23 11.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M21 11.5H23V13.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Insight Hunter</span>
        </a>

        <nav class="nav-links" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <div class="nav-actions">
          <a href="/auth/login" class="nav-login">Sign In</a>
          <a href="/auth/register?plan=lite" class="nav-signup">Start Free</a>
        </div>

        <button class="nav-burger" id="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
        {navLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
        <hr />
        <a href="/auth/login" class="mobile-login">Sign In</a>
        <a href="/auth/register?plan=lite" class="mobile-signup">Create Account</a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.22" />
              <path d="M9 20.5L14 15.5L17.5 18L23 11.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M21 11.5H23V13.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Insight Hunter</span>
          </a>
          <p class="footer-tagline">
            AI CFO software for small businesses that need sharper reporting, better operating visibility, and cleaner follow-through.
          </p>
        </div>

        <div class="footer-cols">
          <div class="footer-col">
            <h4>Platform</h4>
            {platformLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>

          <div class="footer-col">
            <h4>Company</h4>
            {companyLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>

          <div class="footer-col">
            <h4>Account</h4>
            {accountLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <span>&copy; {new Date().getFullYear()} Insight Hunter. All rights reserved.</span>
        <div class="footer-legal">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
        </div>
      </div>
    </footer>

    <script>
      const burger = document.getElementById('nav-burger');
      const mobile = document.getElementById('nav-mobile');
      const nav = document.getElementById('site-nav');

      burger?.addEventListener('click', () => {
        const open = mobile?.classList.toggle('open');
        burger.setAttribute('aria-expanded', String(open));
        mobile?.setAttribute('aria-hidden', String(!open));
      });

      mobile?.querySelectorAll('a').forEach((link) =>
        link.addEventListener('click', () => {
          mobile.classList.remove('open');
          burger?.setAttribute('aria-expanded', 'false');
          mobile?.setAttribute('aria-hidden', 'true');
        }),
      );

      window.addEventListener(
        'scroll',
        () => nav?.classList.toggle('scrolled', window.scrollY > 8),
        { passive: true },
      );
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #07111f;
    --bg-deep: #030914;
    --bg-soft: #0d1727;
    --surface: #101b2c;
    --surface-alt: #152235;
    --surface-glass: rgba(16, 27, 44, 0.72);
    --card: #0f1b2d;
    --border: rgba(123, 149, 182, 0.22);
    --border-dim: rgba(123, 149, 182, 0.14);
    --border-strong: rgba(168, 227, 255, 0.5);
    --white: #eef5ff;
    --muted: #9fb2c7;
    --subtle: #70839a;
    --cyan: #5dd7ff;
    --cyan-text: #c4f5ff;
    --gold: #e78a3b;
    --gold-light: #ffb778;
    --success: #6dd3a3;
    --danger: #ff7c70;
    --warning: #f0b264;

    --font-display: 'General Sans', 'Inter', sans-serif;
    --font-body: 'Satoshi', 'Inter', sans-serif;

    --radius-sm: 10px;
    --radius-card: 18px;
    --radius-xl: 28px;

    --shadow-soft: 0 16px 50px rgba(0, 0, 0, 0.22);
    --shadow-card: 0 18px 44px rgba(0, 0, 0, 0.18);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top, rgba(93, 215, 255, 0.08), transparent 34%),
      linear-gradient(180deg, var(--bg) 0%, var(--bg-deep) 100%);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    margin: 0;
    color: var(--white);
    font-family: var(--font-display);
    line-height: 1.08;
    text-wrap: balance;
  }

  p {
    text-wrap: pretty;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .skip-link {
    position: absolute;
    left: 12px;
    top: -40px;
    z-index: 999;
    padding: 10px 14px;
    border-radius: 10px;
    background: var(--white);
    color: #09111c;
    font-weight: 700;
  }

  .skip-link:focus {
    top: 12px;
  }

  .container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .section {
    padding: 88px 0;
  }

  .card {
    border-radius: var(--radius-card);
    background: linear-gradient(180deg, rgba(17, 28, 44, 0.96), rgba(12, 22, 35, 0.96));
    border: 1px solid var(--border-dim);
    box-shadow: var(--shadow-card);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid rgba(93, 215, 255, 0.18);
    background: rgba(93, 215, 255, 0.08);
    color: var(--cyan-text);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-head {
    max-width: 760px;
    margin: 0 auto 52px;
    text-align: center;
  }

  .section-head h2 {
    margin-bottom: 16px;
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .section-head p {
    margin: 0;
    color: var(--muted);
    font-size: 1.02rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 46px;
    padding: 12px 20px;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-weight: 700;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .btn-gold {
    background: var(--gold);
    color: #0f1115;
  }

  .btn-gold:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  .btn-outline {
    border: 1px solid var(--border);
    background: transparent;
    color: var(--white);
  }

  .btn-outline:hover {
    border-color: var(--border-strong);
    color: var(--cyan-text);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .form-input {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--white);
    padding: 12px 14px;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--border-strong);
    box-shadow: 0 0 0 3px rgba(93, 215, 255, 0.12);
  }

  .form-input::placeholder {
    color: var(--subtle);
  }
</style>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 200;
    border-bottom: 1px solid var(--border-dim);
    background: rgba(4, 10, 19, 0.72);
    backdrop-filter: blur(16px);
    transition: box-shadow 180ms ease, background 180ms ease;
  }

  .nav.scrolled {
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.18);
    background: rgba(4, 10, 19, 0.88);
  }

  .nav-inner {
    width: min(1200px, calc(100% - 40px));
    margin: 0 auto;
    min-height: 72px;
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-logo,
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--white);
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 700;
  }

  .nav-logo svg,
  .footer-logo svg {
    color: var(--cyan);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }

  .nav-links a {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 160ms ease;
  }

  .nav-links a:hover {
    color: var(--white);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
  }

  .nav-login {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 600;
    transition: color 160ms ease;
  }

  .nav-login:hover {
    color: var(--white);
  }

  .nav-signup {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 10px;
    background: var(--gold);
    color: #0f1115;
    font-size: 0.9rem;
    font-weight: 700;
    transition: background 160ms ease, transform 160ms ease;
  }

  .nav-signup:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    margin-left: auto;
    padding: 8px;
    background: transparent;
    border: none;
    color: var(--white);
  }

  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 0 20px 18px;
    border-top: 1px solid var(--border-dim);
    background: rgba(5, 11, 20, 0.98);
  }

  .nav-mobile a {
    padding: 12px 0;
    color: var(--muted);
    border-bottom: 1px solid var(--border-dim);
    font-weight: 500;
  }

  .nav-mobile a:hover {
    color: var(--white);
  }

  .nav-mobile hr {
    width: 100%;
    margin: 10px 0 0;
    border: none;
    border-top: 1px solid var(--border-dim);
  }

  .mobile-signup {
    margin-top: 10px;
    padding: 13px 16px !important;
    border: none !important;
    border-radius: 10px;
    background: var(--gold);
    color: #0f1115 !important;
    text-align: center;
    font-weight: 700 !important;
  }

  .footer {
    border-top: 1px solid var(--border-dim);
    background: rgba(3, 9, 20, 0.94);
    padding: 68px 0 28px;
  }

  .footer-inner {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto 42px;
    display: grid;
    grid-template-columns: minmax(240px, 1fr) auto;
    gap: 48px;
  }

  .footer-brand {
    max-width: 360px;
  }

  .footer-tagline {
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.75;
  }

  .footer-cols {
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
  }

  .footer-col {
    display: flex;
    min-width: 150px;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col h4 {
    margin: 0 0 6px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-col a {
    color: var(--muted);
    font-size: 0.92rem;
    transition: color 160ms ease;
  }

  .footer-col a:hover {
    color: var(--white);
  }

  .footer-bottom {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding-top: 22px;
    border-top: 1px solid var(--border-dim);
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    color: var(--subtle);
    font-size: 0.84rem;
  }

  .footer-legal {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer-legal a:hover {
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .nav-links,
    .nav-actions {
      display: none;
    }

    .nav-burger {
      display: flex;
    }

    .nav-mobile.open {
      display: flex;
    }

    .footer-inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .section {
      padding: 72px 0;
    }

    .container,
    .nav-inner,
    .footer-inner,
    .footer-bottom {
      width: min(100% - 28px, 1180px);
    }

    .footer-cols {
      gap: 28px;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
