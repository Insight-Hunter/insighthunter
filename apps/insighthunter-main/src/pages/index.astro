---
export const prerender = true;

import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/marketing/Hero.astro';
import FeatureGrid from '../components/marketing/FeatureGrid.astro';
import PricingTable from '../components/marketing/PricingTable.astro';
import Testimonials from '../components/marketing/Testimonials.astro';
import CTABanner from '../components/marketing/CTABanner.astro';
import { apps } from '../data/apps';

const featuredApps = apps.slice(0, 6);

const proofPoints = [
  {
    label: 'Faster decisions',
    value: 'Daily',
    detail: 'Cash, margin, receivables, and runway visibility without waiting on month-end close.',
  },
  {
    label: 'Operator workflows',
    value: '6 apps',
    detail: 'Bookkeeping, AI CFO, payroll, PBX, reporting, and formation tools inside one platform.',
  },
  {
    label: 'Upgrade path',
    value: 'Edge-native',
    detail: 'Built for Cloudflare-first auth, routing, analytics, and multi-tenant service isolation.',
  },
];

const operatingLanes = [
  {
    title: 'See the business clearly',
    text: 'Track revenue, expenses, net income, working capital, and cash flow in one operational view instead of stitching together spreadsheets and point tools.',
  },
  {
    title: 'Act from the same workspace',
    text: 'Move from anomaly detection to bookkeeping, payroll, entity setup, receivables, and reporting without leaving the platform.',
  },
  {
    title: 'Grow without re-platforming',
    text: 'Start small with one focused workflow, then unlock forecasting, AI guidance, and higher-control tiers as customers, complexity, and team size grow.',
  },
];

const launchCards = [
  {
    title: 'For owners',
    text: 'Get a cleaner answer to “what is happening in my business right now?” with plain-language insights and sharp KPI visibility.',
  },
  {
    title: 'For accountants',
    text: 'Standardize operational reporting, reduce client back-and-forth, and give small businesses a finance stack they can actually use.',
  },
  {
    title: 'For investors',
    text: 'Present a credible edge-native SaaS: multi-tenant architecture, monetized tiers, protected access flows, and real expansion paths.',
  },
];
---

<MarketingLayout
  title="Insight Hunter | AI CFO software for small business operators"
  description="Insight Hunter gives small businesses an AI CFO workspace for reporting, forecasting, bookkeeping, payroll, entity formation, and operating visibility."
>
  <Hero />

  <section class="section section-proof">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Operating system for finance</span>
        <h2>One place to understand the numbers and act on them.</h2>
        <p>
          Insight Hunter is designed for small businesses that need CFO-grade visibility without buying an enterprise finance team or juggling disconnected software.
        </p>
      </div>

      <div class="proof-grid">
        {proofPoints.map((point) => (
          <article class="proof-card card">
            <p class="proof-label">{point.label}</p>
            <h3>{point.value}</h3>
            <p>{point.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-lanes">
    <div class="container lanes-shell card">
      <div class="section-head section-head-inline">
        <div>
          <span class="eyebrow">Why it converts</span>
          <h2>Built for the bottlenecks that keep small businesses flying blind.</h2>
        </div>
        <p>
          Most teams do not need more dashboards. They need a workflow that turns financial data into decisions, follow-through, and better customer outcomes.
        </p>
      </div>

      <div class="lanes-grid">
        {operatingLanes.map((lane, index) => (
          <article class="lane-card">
            <span class="lane-index">0{index + 1}</span>
            <h3>{lane.title}</h3>
            <p>{lane.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="apps">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Product suite</span>
        <h2>Start with one workflow. Expand into a full finance stack.</h2>
        <p>
          Each app solves a real business bottleneck on its own, but they work better together as one operating layer for reporting, compliance, payments, labor, and customer service.
        </p>
      </div>

      <div class="app-grid">
        {featuredApps.map((app) => (
          <a class="app-card card" href={`/${app.slug}`}>
            <div class="app-card-top">
              <span class="app-icon" aria-hidden="true">{app.icon}</span>
              <span class="app-tier">{app.tier}</span>
            </div>
            <h3>{app.name}</h3>
            <p>{app.description}</p>
            <span class="app-link">Open product page &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FeatureGrid />

  <section class="section section-launch">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Who it serves</span>
        <h2>A cleaner story for customers, partners, and investors.</h2>
      </div>

      <div class="launch-grid">
        {launchCards.map((card) => (
          <article class="launch-card card">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />
  <PricingTable />
  <CTABanner
    title="Start with visibility. Upgrade into execution."
    text="Create your account, complete onboarding, and move from reporting into payroll, entity formation, AI guidance, and deeper operating control."
    cta={{ href: '/auth/register?plan=lite', label: 'Create Account' }}
  />
</MarketingLayout>

<style>
  .section-proof,
  .section-launch {
    position: relative;
  }

  .proof-grid,
  .launch-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .proof-card,
  .launch-card,
  .lane-card,
  .app-card {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 84%, transparent), color-mix(in srgb, var(--surface-alt) 92%, transparent));
    border: 1px solid var(--border-dim);
  }

  .proof-card {
    padding: 24px;
    min-height: 220px;
  }

  .proof-label {
    margin: 0 0 12px;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .proof-card h3 {
    margin: 0 0 12px;
    font-size: clamp(1.8rem, 2.6vw, 2.75rem);
    line-height: 1;
    color: var(--white);
  }

  .proof-card p:last-child {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .lanes-shell {
    padding: 28px;
  }

  .section-head-inline {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 20px;
    align-items: end;
    margin-bottom: 24px;
  }

  .section-head-inline p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .lanes-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .lane-card {
    padding: 22px;
    border-radius: 16px;
  }

  .lane-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    margin-bottom: 16px;
    border-radius: 999px;
    border: 1px solid var(--border-dim);
    background: var(--surface-alt);
    color: var(--cyan-text);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .lane-card h3,
  .launch-card h3,
  .app-card h3 {
    margin: 0 0 10px;
    font-size: 1.05rem;
    color: var(--white);
  }

  .lane-card p,
  .launch-card p,
  .app-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }

  .app-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .app-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-strong, var(--cyan-text));
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
  }

  .app-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }

  .app-icon {
    font-size: 1.6rem;
  }

  .app-tier {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--surface-alt);
    border: 1px solid var(--border-dim);
    border-radius: 999px;
    padding: 4px 10px;
  }

  .app-link {
    margin-top: auto;
    padding-top: 10px;
    font-size: 0.84rem;
    color: var(--cyan-text);
    font-weight: 600;
  }

  .launch-card {
    padding: 24px;
    min-height: 180px;
  }

  @media (max-width: 960px) {
    .proof-grid,
    .launch-grid,
    .lanes-grid,
    .section-head-inline {
      grid-template-columns: 1fr;
    }

    .lanes-shell {
      padding: 22px;
    }
  }
</style>
