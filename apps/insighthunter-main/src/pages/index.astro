---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import PlatformStrip from "../components/PlatformStrip.astro";
import AppsGrid from "../components/AppsGrid.astro";
import Architecture from "../components/Architecture.astro";
import FeaturesDeepDive from "../components/FeaturesDeepDive.astro";
import PricingSection from "../components/PricingSection.astro";
import Integrations from "../components/Integrations.astro";
import CTASection from "../components/CTASection.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
---

<BaseLayout title={site.meta.title} description={site.meta.description}>
  <Nav links={site.navLinks} />
  <Hero hero={site.hero} />
  <PlatformStrip items={site.platformStrip} />
  <AppsGrid apps={site.apps} />
  <Architecture arch={site.architecture} />
  <FeaturesDeepDive features={site.features} />
  <PricingSection pricing={site.pricing} addons={site.addons} />
  <Integrations integrations={site.integrations} />
  <CTASection cta={site.cta} />
  <Footer footer={site.footer} />
</BaseLayout>