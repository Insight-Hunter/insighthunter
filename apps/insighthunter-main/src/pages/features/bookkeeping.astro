---
// src/pages/features/bookkeeping.astro
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Bookkeeping | Insight Hunter"
  description="Monthly close support, cleaner books, categorized transactions, and reporting visibility for small businesses."
>
  <section class="container section split">
    <div>
      <span class="eyebrow">Bookkeeping</span>
      <h1>Books you can actually run the business from.</h1>
      <p>Turn messy transactions, missing categorizations, and lagging reconciliations into dependable monthly reporting.</p>
      <div class="actions">
        <a href="/bookkeeping">Open app homepage</a>
        <a href="https://auth.insighthunter.app/signup?plan=free">Start setup</a>
      </div>
    </div>
    <div class="panel">
      <h2>What it covers</h2>
      <ul>
        <li>Monthly close workflow.</li>
        <li>Transaction review and cleanup.</li>
        <li>P&L and cash visibility.</li>
        <li>Owner-ready reporting outputs.</li>
      </ul>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .split { display: grid; grid-template-columns: 1.25fr .85fr; gap: 1rem; }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1.25rem; }
  .actions { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1.25rem; }
  .actions a { padding: .85rem 1.1rem; border-radius: 999px; border: 1px solid rgba(84,72,56,.18); text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
  @media (max-width: 840px) { .split { grid-template-columns: 1fr; } }
</style>
