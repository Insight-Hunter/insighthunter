---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Insight Pro | Insight Hunter" description="Advanced visibility, execution, and decision support for more demanding operators.">
  <section class="container section">
    <span class="eyebrow">Insight Pro</span>
    <h1>Run a tighter business with deeper support.</h1>
    <p>Insight Pro is designed for operators who need stronger forecasting, better reporting, and more structured execution support across the business.</p>
    <div class="actions">
      <a href="/insight-pro">Open app homepage</a>
      <a href="/contact">Talk to sales</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border: 1px solid rgba(84,72,56,.18); border-radius: 999px; text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
