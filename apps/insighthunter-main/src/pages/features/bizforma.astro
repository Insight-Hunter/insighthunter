---
// src/pages/features/bizforma.astro
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="BizForma | Insight Hunter" description="Business formation guidance, setup workflow, and compliance tracking in one launch app.">
  <section class="container section split">
    <div>
      <span class="eyebrow">BizForma</span>
      <h1>Launch the company with fewer blind spots.</h1>
      <p>Move from idea to registered entity with structured setup, paperwork guidance, tax/account readiness, and compliance visibility.</p>
      <div class="actions">
        <a href="/bizforma">Open app homepage</a>
        <a href="https://auth.insighthunter.app/signup?plan=free">Create account</a>
      </div>
    </div>
    <div class="panel">
      <h2>Core workflow</h2>
      <ul>
        <li>Entity planning.</li>
        <li>Registration checklist.</li>
        <li>EIN and tax setup guidance.</li>
        <li>Compliance reminders.</li>
      </ul>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .split { display: grid; grid-template-columns: 1.25fr .85fr; gap: 1rem; }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1.25rem; }
  .actions { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1.25rem; }
  .actions a { padding: .85rem 1.1rem; border-radius: 999px; border: 1px solid rgba(84,72,56,.18); text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
