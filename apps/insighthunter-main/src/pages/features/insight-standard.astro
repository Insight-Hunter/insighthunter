---
// src/pages/features/insight-standard.astro
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Insight Standard | Insight Hunter" description="A stronger operating layer for teams that need deeper visibility and more structure.">
  <section class="container section">
    <span class="eyebrow">Insight Standard</span>
    <h1>Move from basic reporting to managed control.</h1>
    <p>Insight Standard expands visibility, reporting discipline, and team coordination for businesses that are outgrowing lightweight tools.</p>
    <div class="actions">
      <a href="/insight-standard">Open app homepage</a>
      <a href="/pricing">Compare plans</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border: 1px solid rgba(84,72,56,.18); border-radius: 999px; text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
