---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Website Services | Insight Hunter" description="Website build, refresh, and conversion-focused web support for small businesses.">
  <section class="container section">
    <span class="eyebrow">Website Services</span>
    <h1>Launch a site that actually supports the business.</h1>
    <p>Use Website Services for landing pages, business sites, refresh work, and web support aligned with offers, operations, and sales goals.</p>
    <div class="actions">
      <a href="/website-services">Open app homepage</a>
      <a href="/contact">Request a website plan</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border: 1px solid rgba(84,72,56,.18); border-radius: 999px; text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
