---
// src/pages/features/insight-lite.astro
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Insight Lite | Insight Hunter" description="Essential visibility for owners who need clarity without enterprise complexity.">
  <section class="container section">
    <span class="eyebrow">Insight Lite</span>
    <h1>Start with the essentials.</h1>
    <p>Insight Lite gives smaller operators clean financial visibility, simple metrics, and a practical starting point for disciplined reporting.</p>
    <div class="actions">
      <a href="/insight-lite">Open app homepage</a>
      <a href="/pricing">See pricing</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border: 1px solid rgba(84,72,56,.18); border-radius: 999px; text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
