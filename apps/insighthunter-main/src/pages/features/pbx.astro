---
// src/pages/features/pbx.astro
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="PBX | Insight Hunter" description="Business phone operations, routing visibility, and communication support from one focused system.">
  <section class="container section">
    <span class="eyebrow">PBX</span>
    <h1>Keep business calls organized and accountable.</h1>
    <p>PBX gives small teams a cleaner phone workflow, better routing visibility, and a more reliable communications layer.</p>
    <div class="actions">
      <a href="/pbx">Open app homepage</a>
      <a href="/contact">Request setup</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border: 1px solid rgba(84,72,56,.18); border-radius: 999px; text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
