---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Contact">
  <section style="max-width:var(--content-narrow);margin:0 auto;padding:clamp(var(--space-12),6vw,var(--space-20)) var(--space-6);">
    <h1 style="font-family:var(--font-display);font-size:var(--text-2xl);font-style:italic;margin-bottom:var(--space-3);">Get in touch.</h1>
    <p style="color:var(--color-text-muted);margin-bottom:var(--space-8);">Questions about pricing, white-label licensing, or enterprise? We reply within one business day.</p>
    <form method="POST" action="/api/contact" style="display:flex;flex-direction:column;gap:var(--space-4);">
      <label>
        <span style="font-size:var(--text-sm);font-weight:500;">Name</span>
        <input name="name" type="text" required style="display:block;width:100%;margin-top:var(--space-1);padding:var(--space-2) var(--space-3);border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);font-size:var(--text-sm);" />
      </label>
      <label>
        <span style="font-size:var(--text-sm);font-weight:500;">Email</span>
        <input name="email" type="email" required style="display:block;width:100%;margin-top:var(--space-1);padding:var(--space-2) var(--space-3);border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);font-size:var(--text-sm);" />
      </label>
      <label>
        <span style="font-size:var(--text-sm);font-weight:500;">Message</span>
        <textarea name="message" rows="5" required style="display:block;width:100%;margin-top:var(--space-1);padding:var(--space-2) var(--space-3);border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);font-size:var(--text-sm);resize:vertical;"></textarea>
      </label>
      <button type="submit" class="btn btn-primary">Send message</button>
    </form>
  </section>
</MarketingLayout>
