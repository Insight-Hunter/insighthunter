---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Nav from '../components/marketing/Nav.astro';
---
<MarketingLayout title="Contact">
  <Nav />
  <section style="max-width:640px;margin:0 auto;padding:clamp(60px,6vw,120px) 24px;">
    <h1 style="font-family:var(--font-display);font-size:2.5rem;font-style:italic;margin-bottom:12px;">Get in touch.</h1>
    <p style="color:var(--muted);margin-bottom:40px;">Questions about pricing, white-label licensing, or enterprise? We reply within one business day.</p>
    <form method="POST" action="/api/contact" style="display:flex;flex-direction:column;gap:20px;">
      <label>
        <span style="font-size:0.875rem;font-weight:500;display:block;margin-bottom:6px;">Name</span>
        <input name="name" type="text" required style="display:block;width:100%;padding:10px 14px;border:1px solid rgba(255,255,255,.12);border-radius:8px;background:rgba(255,255,255,.04);color:#fff;font-size:0.9rem;" />
      </label>
      <label>
        <span style="font-size:0.875rem;font-weight:500;display:block;margin-bottom:6px;">Email</span>
        <input name="email" type="email" required style="display:block;width:100%;padding:10px 14px;border:1px solid rgba(255,255,255,.12);border-radius:8px;background:rgba(255,255,255,.04);color:#fff;font-size:0.9rem;" />
      </label>
      <label>
        <span style="font-size:0.875rem;font-weight:500;display:block;margin-bottom:6px;">Message</span>
        <textarea name="message" rows="5" required style="display:block;width:100%;padding:10px 14px;border:1px solid rgba(255,255,255,.12);border-radius:8px;background:rgba(255,255,255,.04);color:#fff;font-size:0.9rem;resize:vertical;"></textarea>
      </label>
      <button type="submit" class="btn btn-gold">Send message</button>
    </form>
  </section>
</MarketingLayout>
