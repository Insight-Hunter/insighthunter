---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Contact | Insight Hunter"
  description="Talk to Insight Hunter about bookkeeping, reporting, payroll, BizForma, or multi-app rollout."
>
  <section class="container section split">
    <div>
      <span class="eyebrow">Contact</span>
      <h1>Tell us what is slowing the business down.</h1>
      <p>Whether you need cleaner books, better reporting, a launch plan, or app selection help, this is the fastest way to start the conversation.</p>
      <div class="info-list">
        <div><strong>Email</strong><p>hello@insighthunter.app</p></div>
        <div><strong>Best for</strong><p>Bookkeeping, rollout planning, pricing, and implementation.</p></div>
        <div><strong>Response</strong><p>Usually within one business day.</p></div>
      </div>
    </div>

    <form class="panel form-grid" method="post" action="/api/contact">
      <label>
        Name
        <input type="text" name="name" required />
      </label>
      <label>
        Email
        <input type="email" name="email" required />
      </label>
      <label>
        Company
        <input type="text" name="company" />
      </label>
      <label>
        Primary need
        <select name="need">
          <option>Bookkeeping</option>
          <option>Forecasting</option>
          <option>BizForma</option>
          <option>Payroll</option>
          <option>PBX</option>
          <option>Website services</option>
          <option>Multi-app rollout</option>
        </select>
      </label>
      <label class="full">
        Message
        <textarea name="message" rows="6" required></textarea>
      </label>
      <button type="submit">Send request</button>
    </form>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1.25rem; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .full { grid-column: 1 / -1; }
  label { display: grid; gap: .45rem; font-weight: 600; }
  input, select, textarea { width: 100%; padding: .85rem 1rem; border-radius: 12px; border: 1px solid rgba(84,72,56,.18); background: rgba(255,255,255,.75); }
  button { border: none; border-radius: 999px; padding: .95rem 1.2rem; background: #2f6c62; color: white; font-weight: 700; }
  .info-list { display: grid; gap: .75rem; margin-top: 1.25rem; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
  @media (max-width: 840px) { .split, .form-grid { grid-template-columns: 1fr; } }
</style>
