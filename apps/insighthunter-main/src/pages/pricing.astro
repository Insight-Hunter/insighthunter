---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PricingTable from '../components/marketing/PricingTable.astro';
import CTABanner from '../components/marketing/CTABanner.astro';
import { pricingTiers } from '../data/pricing';
---

<MarketingLayout
  title="Pricing | Insight Hunter"
  description="Simple pricing for operators who need clarity, execution, and finance-grade visibility."
>
  <section class="container section hero-block">
    <span class="eyebrow">Pricing</span>
    <h1>Choose the level of visibility you need.</h1>
    <p>Start lean, then unlock deeper reporting, workflow support, and app access as your business complexity increases.</p>
  </section>

  <PricingTable />

  <section class="container section">
    <div class="faq-grid">
      {pricingTiers.map((tier) => (
        <article class="faq-card">
          <h2>{tier.name}</h2>
          <p>{tier.description}</p>
          <ul>
            {tier.features?.slice(0, 5).map((feature) => <li>{feature}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <CTABanner
    title="Need a bundled rollout?"
    text="Use one plan to start, then layer in bookkeeping, forecasting, BizForma, payroll, or operator support as needed."
    cta={{ href: '/contact', label: 'Talk to Insight Hunter' }}
  />
</MarketingLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .hero-block { max-width: 760px; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
  .faq-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; }
  .faq-card { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1.25rem; }
  ul { padding-left: 1rem; }
</style>
