---
export const prerender = true;

import MarketingLayout from '../layouts/MarketingLayout.astro';
import PricingTable from '../components/marketing/PricingTable.astro';
import CTABanner from '../components/marketing/CTABanner.astro';

const buyingSignals = [
  {
    title: 'Start free',
    text: 'Open an account, explore the platform, and move into paid workflows only when your operating needs justify it.',
  },
  {
    title: 'Upgrade by complexity',
    text: 'Add reporting depth, AI guidance, bookkeeping, payroll, and operator tooling as revenue, team size, and workflow load increase.',
  },
  {
    title: 'Stay aligned',
    text: 'Use one platform for financial visibility, execution, and customer-ready operations instead of stacking disconnected point solutions.',
  },
];

const fitGuides = [
  {
    tier: 'Free / Lite',
    audience: 'Solo operators, early-stage businesses, and owners who need clarity before complexity.',
  },
  {
    tier: 'Standard',
    audience: 'Growing companies that need structured reporting, more app access, and stronger operating discipline.',
  },
  {
    tier: 'Pro / Enterprise',
    audience: 'Teams that want deeper control, multi-workflow adoption, premium support, and broader rollout capacity.',
  },
];

const pricingFaqs = [
  {
    question: 'Can I start small and upgrade later?',
    answer: 'Yes. Insight Hunter is designed to let customers begin with a narrow use case, then unlock deeper reporting, AI, payroll, formation, and operating workflows over time.',
  },
  {
    question: 'Do I need every app on day one?',
    answer: 'No. The platform is intentionally modular, so customers can adopt the highest-value workflow first and expand only when the business is ready.',
  },
  {
    question: 'Is this built for real operational use?',
    answer: 'Yes. The product direction is a Cloudflare-native, multi-tenant SaaS built around customer accounts, protected access, tiered entitlements, and scalable service routing.',
  },
];
---

<MarketingLayout
  title="Pricing | Insight Hunter"
  description="Transparent pricing for small businesses that need AI CFO visibility, sharper reporting, and a clean upgrade path into a full finance operating stack."
>
  <section class="pricing-hero section">
    <div class="container pricing-hero-inner">
      <span class="eyebrow">Pricing</span>
      <h1>Choose the level of financial visibility and operating control you need.</h1>
      <p class="hero-copy">
        Start lean, prove value quickly, and upgrade into deeper reporting, AI guidance, bookkeeping, payroll, and operator workflows as your business grows.
      </p>

      <div class="hero-actions">
        <a class="btn btn-gold" href="/auth/register?plan=lite">Create Account</a>
        <a class="btn btn-outline" href="/contact">Talk to Sales</a>
      </div>

      <div class="signal-grid">
        {buyingSignals.map((signal) => (
          <article class="signal-card card">
            <h2>{signal.title}</h2>
            <p>{signal.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-fit">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">How to buy</span>
        <h2>Buy for the bottleneck you have now, not the stack you might need later.</h2>
        <p>
          The best-fit plan usually depends on workflow complexity, reporting expectations, and how many parts of the business you want managed inside one system.
        </p>
      </div>

      <div class="fit-grid">
        {fitGuides.map((item) => (
          <article class="fit-card card">
            <span class="fit-tier">{item.tier}</span>
            <p>{item.audience}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <PricingTable />

  <section class="section section-faq">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Questions</span>
        <h2>Common buying questions.</h2>
      </div>

      <div class="faq-list">
        {pricingFaqs.map((faq) => (
          <article class="faq-card card">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="Need a bundled rollout?"
    text="Layer in bookkeeping, forecasts, BizForma, payroll, or broader operator support based on your current bottleneck and growth plan."
    cta={{ href: '/contact', label: 'Talk to Insight Hunter' }}
  />
</MarketingLayout>

<style>
  .pricing-hero {
    position: relative;
    overflow: hidden;
  }

  .pricing-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top center, rgba(93, 215, 255, 0.12), transparent 36%),
      linear-gradient(180deg, rgba(10, 22, 36, 0.78), rgba(5, 10, 18, 0.18));
    pointer-events: none;
  }

  .pricing-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1080px;
  }

  .pricing-hero h1 {
    max-width: 880px;
    margin-bottom: 18px;
    font-size: clamp(2.3rem, 5vw, 4.4rem);
    letter-spacing: -0.03em;
  }

  .hero-copy {
    max-width: 720px;
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 28px;
    flex-wrap: wrap;
  }

  .signal-grid,
  .fit-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .signal-grid {
    margin-top: 34px;
  }

  .signal-card,
  .fit-card,
  .faq-card {
    padding: 24px;
    border: 1px solid var(--border-dim);
    background:
      linear-gradient(180deg, rgba(18, 28, 43, 0.95), rgba(11, 20, 32, 0.95));
  }

  .signal-card h2 {
    margin-bottom: 10px;
    font-size: 1.05rem;
  }

  .signal-card p,
  .fit-card p,
  .faq-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .section-fit {
    padding-top: 32px;
  }

  .fit-tier {
    display: inline-flex;
    margin-bottom: 12px;
    border-radius: 999px;
    border: 1px solid rgba(93, 215, 255, 0.22);
    background: rgba(93, 215, 255, 0.08);
    color: var(--cyan-text);
    padding: 6px 12px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .faq-list {
    display: grid;
    gap: 16px;
    max-width: 920px;
    margin: 0 auto;
  }

  .faq-card h3 {
    margin-bottom: 10px;
    font-size: 1.05rem;
  }

  @media (max-width: 960px) {
    .signal-grid,
    .fit-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .pricing-hero h1 {
      font-size: clamp(2rem, 11vw, 3rem);
    }

    .hero-copy {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions .btn {
      width: 100%;
    }
  }
</style>
