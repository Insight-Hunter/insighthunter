---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PricingTable from '../components/marketing/PricingTable.astro';
import CTABanner from '../components/marketing/CTABanner.astro';
---
<MarketingLayout title="Pricing">
  <PricingTable />
  <section style="background:var(--color-surface);padding:var(--space-12) var(--space-6);text-align:center;">
    <h2 style="font-family:var(--font-display);font-size:var(--text-xl);font-style:italic;margin-bottom:var(--space-3);">Need a white-label license?</h2>
    <p style="color:var(--color-text-muted);max-width:52ch;margin:0 auto var(--space-5);">Fractional CFOs and accounting practices can license the full platform under their own brand.</p>
    <a href="/contact" class="btn btn-primary">Contact Sales</a>
  </section>
  <CTABanner />
</MarketingLayout>
