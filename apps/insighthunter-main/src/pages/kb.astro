---
import MarketingLayout from '../layouts/MarketingLayout.astro';
const posts = await Astro.glob('./kb/*.md');
---
<MarketingLayout title="InsightHunter Knowledge Base">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-8">Knowledge Base</h1>
    <ul class="space-y-4">
      {posts.map((post) => (
        <li>
          <a href={post.url} class="text-2xl font-semibold text-blue-600 hover:underline">
            {post.frontmatter.title || post.file.split('/').pop().replace('.md', '')}
          </a>
          <p class="text-gray-600">{post.frontmatter.description}</p>
        </li>
      ))}
    </ul>
  </div>
</MarketingLayout>
