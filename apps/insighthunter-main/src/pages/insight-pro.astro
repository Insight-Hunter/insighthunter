---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Insight Pro App | Insight Hunter" description="Homepage for Insight Pro.">
  <section class="container section app-home">
    <span class="eyebrow">Insight Pro</span>
    <h1>Deeper control for more demanding operators.</h1>
    <p>This route acts as the dedicated app homepage for Insight Pro and supports product-specific subdomain landing.</p>
    <div class="actions">
      <a href="https://auth.insighthunter.app/signup?plan=pro">Request access</a>
      <a href="/contact">Talk to Insight Hunter</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border-radius: 999px; border: 1px solid rgba(84,72,56,.18); text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
