---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import type { AuthUser } from '@ih/types';
const user = Astro.locals.user as AuthUser;
---
<DashboardLayout title="Settings">
  <div class="card" style="max-width:600px">
    <h2 style="font-family:var(--font-display);font-size:1.25rem;margin-bottom:var(--space-6);">Account Settings</h2>
    <form id="settings-form" style="display:flex;flex-direction:column;gap:var(--space-4);">
      <div class="form-group">
        <label>Full name</label>
        <input type="text" class="input" id="name" value={user?.name ?? ''} />
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" class="input" value={user?.email ?? ''} disabled />
      </div>
      <div class="form-group">
        <label>Current password</label>
        <input type="password" class="input" id="current-password" placeholder="Leave blank to keep unchanged" />
      </div>
      <div class="form-group">
        <label>New password</label>
        <input type="password" class="input" id="new-password" placeholder="Leave blank to keep unchanged" />
      </div>
      <div id="settings-msg" style="font-size:0.875rem;min-height:20px;color:var(--color-success)"></div>
      <button type="submit" class="btn btn--primary" style="align-self:flex-start">Save changes</button>
    </form>
  </div>
  <script>
    document.getElementById('settings-form')?.addEventListener('submit', async e => {
      e.preventDefault();
      const token = localStorage.getItem('ih_access_token');
      const body: Record<string, string> = {};
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const cp = (document.getElementById('current-password') as HTMLInputElement).value;
      const np = (document.getElementById('new-password') as HTMLInputElement).value;
      if (name) body.name = name;
      if (cp && np) { body.current_password = cp; body.new_password = np; }
      const res = await fetch('/api/auth/profile', {
        method: 'PATCH', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify(body),
      });
      const msg = document.getElementById('settings-msg')!;
      if (res.ok) { msg.style.color = 'var(--color-success)'; msg.textContent = 'Settings saved.'; }
      else { const d = await res.json() as { error?: string }; msg.style.color = 'var(--color-danger)'; msg.textContent = d.error ?? 'Error saving settings.'; }
    });
  </script>
</DashboardLayout>
