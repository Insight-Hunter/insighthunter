---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Settings">
  <section class="dashboard-page">
    <p class="eyebrow">Settings</p>
    <h1>Organization and account settings</h1>
    <div class="grid">
      <article class="panel"><h2>Workspace</h2><p>Manage organization profile, defaults, and environment settings.</p></article>
      <article class="panel"><h2>Members</h2><p>Invite users, define access, and control app-level permissions.</p></article>
      <article class="panel"><h2>Billing</h2><p>Review plan, invoices, and upgrade paths in one place.</p></article>
    </div>
  </section>
</DashboardLayout>

<style>
  .dashboard-page { display: grid; gap: 1rem; }
  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1rem; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; margin: 0; }
</style>
