---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="BizForma">
  <section class="dashboard-page">
    <p class="eyebrow">BizForma</p>
    <h1>Business formation cases</h1>
    <div class="grid">
      <article class="panel"><h2>Formation pipeline</h2><p>Track stage, blockers, and next actions across open company launches.</p></article>
      <article class="panel"><h2>State filing status</h2><p>Keep registrations, tax setup, and compliance requirements visible.</p></article>
      <article class="panel"><h2>Client readiness</h2><p>See missing documents, unanswered questions, and deadlines at a glance.</p></article>
    </div>
  </section>
</DashboardLayout>

<style>
  .dashboard-page { display: grid; gap: 1rem; }
  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1rem; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; margin: 0; }
</style>
