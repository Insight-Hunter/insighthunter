---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TierGate from '../../components/dashboard/TierGate.astro';
---
<DashboardLayout title="Insights">
  <TierGate required="lite">
    <div class="card">
      <h3 style="font-family:var(--font-display);margin-bottom:var(--space-4);">AI-Generated Insights</h3>
      <p style="color:var(--color-text-muted);font-size:0.875rem;margin-bottom:var(--space-6);">Ask your AI CFO to analyze your financial data and surface insights, anomalies, and trends.</p>
      <a href="/dashboard/ai" class="btn btn--primary">Open AI CFO Assistant →</a>
    </div>
  </TierGate>
</DashboardLayout>
