---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { pricingTiers } from '../../data/pricing';
---

<DashboardLayout title="Upgrade">
  <section class="dashboard-page">
    <p class="eyebrow">Upgrade</p>
    <h1>Expand your access</h1>
    <div class="grid">
      {pricingTiers.map((tier) => (
        <article class="panel">
          <h2>{tier.name}</h2>
          <p>{tier.description}</p>
          <a href="/pricing">Review tier</a>
        </article>
      ))}
    </div>
  </section>
</DashboardLayout>

<style>
  .dashboard-page { display: grid; gap: 1rem; }
  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1rem; }
  a { text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; margin: 0; }
</style>
