---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { TIER_PRICING, TIER_LIMITS } from '@ih/tier-config';
import type { Tier, AuthUser } from '@ih/types';
const user = Astro.locals.user as AuthUser;
const tiers: Tier[] = ['free', 'lite', 'standard', 'pro', 'enterprise'];
---
<DashboardLayout title="Upgrade Plan">
  <h2 style="font-family:var(--font-display);font-size:1.75rem;margin-bottom:var(--space-8);">Choose your plan</h2>
  <div class="upgrade-grid">
    {tiers.map(tier => {
      const limits = TIER_LIMITS[tier];
      const isCurrent = user?.tier === tier;
      return (
        <div class={`upgrade-card ${isCurrent ? 'upgrade-card--current' : ''}`}>
          {isCurrent && <div class="upgrade-card__badge">Current plan</div>}
          <div class="upgrade-card__tier">{tier.charAt(0).toUpperCase() + tier.slice(1)}</div>
          <div class="upgrade-card__price">${TIER_PRICING[tier]}<span>/mo</span></div>
          <ul class="upgrade-card__features">
            <li>{limits.transactions_per_month === null ? 'Unlimited transactions' : `${limits.transactions_per_month} transactions/mo`}</li>
            <li>{limits.ai_queries_per_day === null ? 'Unlimited AI queries' : limits.ai_queries_per_day === 0 ? 'No AI assistant' : `${limits.ai_queries_per_day} AI queries/day`}</li>
            <li>{limits.payroll_employees === null ? 'Unlimited employees' : limits.payroll_employees === 0 ? 'No payroll' : `${limits.payroll_employees} employees`}</li>
            <li>{limits.pbx_extensions === null ? 'Unlimited extensions' : limits.pbx_extensions === 0 ? 'No PBX' : `${limits.pbx_extensions} extensions`}</li>
            {limits.custom_worker && <li>✓ Dedicated worker runtime</li>}
            {limits.white_label && <li>✓ White-label</li>}
            {limits.sla_hours && <li>✓ {limits.sla_hours}h SLA</li>}
          </ul>
          {!isCurrent && (
            <a href={`mailto:sales@insighthunter.app?subject=Upgrade to ${tier}`} class="btn btn--primary" style="width:100%;justify-content:center;margin-top:auto;">
              {TIER_PRICING[tier] > TIER_PRICING[user?.tier ?? 'free'] ? 'Upgrade' : 'Downgrade'}
            </a>
          )}
        </div>
      );
    })}
  </div>
</DashboardLayout>
<style>
  .upgrade-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: var(--space-4); }
  .upgrade-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); position: relative; }
  .upgrade-card--current { border-color: var(--sand-500); box-shadow: var(--shadow-md); }
  .upgrade-card__badge { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: var(--sand-600); color: white; font-size: 0.7rem; font-weight: 600; padding: 2px 10px; border-radius: var(--radius-full); white-space: nowrap; }
  .upgrade-card__tier { font-weight: 600; color: var(--color-text-muted); font-size: 0.875rem; text-transform: capitalize; }
  .upgrade-card__price { font-family: var(--font-display); font-size: 2rem; font-weight: 700; }
  .upgrade-card__price span { font-size: 0.875rem; font-weight: 400; color: var(--color-text-muted); }
  .upgrade-card__features { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); font-size: 0.8rem; color: var(--color-text-muted); flex: 1; }
  .upgrade-card__features li::before { content: '· '; }
</style>
