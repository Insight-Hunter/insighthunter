---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
const tiers = ['free', 'lite', 'standard', 'pro', 'enterprise'];
const pricing: Record<string, number> = { free: 0, lite: 19, standard: 49, pro: 99, enterprise: 299 };
---
<MarketingLayout title="Upgrade Plan">
  <section class="container" style="padding:60px 24px">
    <h1 style="font-family:var(--font-display);font-size:2rem;margin-bottom:32px">Choose your plan</h1>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;">
      {tiers.map(tier => (
        <div class="card" style="padding:24px;display:flex;flex-direction:column;gap:12px;">
          <div style="font-weight:600;color:var(--muted);font-size:0.875rem;text-transform:capitalize;">{tier}</div>
          <div style="font-family:var(--font-display);font-size:2rem;font-weight:700;">${pricing[tier]}<span style="font-size:0.875rem;font-weight:400;color:var(--muted);">/mo</span></div>
          <a href={`mailto:sales@insighthunter.app?subject=Upgrade to ${tier}`}
            style="background:var(--gold);color:#000;font-weight:700;padding:10px;border-radius:8px;text-align:center;font-size:0.875rem;margin-top:auto;">
            Select
          </a>
        </div>
      ))}
    </div>
  </section>
</MarketingLayout>
