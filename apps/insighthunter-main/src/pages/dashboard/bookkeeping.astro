---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Bookkeeping">
  <section class="dashboard-page">
    <p class="eyebrow">Bookkeeping</p>
    <h1>Bookkeeping operations</h1>
    <div class="grid">
      <article class="panel"><h2>Close status</h2><p>Track what is reconciled, pending, or blocked for the current month.</p></article>
      <article class="panel"><h2>Review queue</h2><p>Prioritize uncategorized activity, anomalies, and owner questions.</p></article>
      <article class="panel"><h2>Reporting handoff</h2><p>Move closed books into management reporting without manual scramble.</p></article>
    </div>
  </section>
</DashboardLayout>

<style>
  .dashboard-page { display: grid; gap: 1rem; }
  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1rem; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; margin: 0; }
</style>
