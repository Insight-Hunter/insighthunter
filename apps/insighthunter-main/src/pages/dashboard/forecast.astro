---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Forecast">
  <section class="dashboard-page">
    <p class="eyebrow">Forecast</p>
    <h1>Cash flow forecasting</h1>
    <div class="grid">
      <article class="panel"><h2>Base case</h2><p>Project the next 13 weeks of expected inflows and outflows.</p></article>
      <article class="panel"><h2>Stress case</h2><p>See what happens if revenue slips or key expenses rise.</p></article>
      <article class="panel"><h2>Decision triggers</h2><p>Know when to cut spend, push collections, or add financing.</p></article>
    </div>
  </section>
</DashboardLayout>

<style>
  .dashboard-page { display: grid; gap: 1rem; }
  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1rem; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; margin: 0; }
</style>
