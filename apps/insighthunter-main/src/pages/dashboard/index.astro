---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import KPICard from '../../components/dashboard/KPICard.svelte';
import RevenueChart from '../../components/dashboard/RevenueChart.svelte';
import CashFlowChart from '../../components/dashboard/CashFlowChart.svelte';
import InsightCard from '../../components/dashboard/InsightCard.svelte';
import ActivityFeed from '../../components/dashboard/ActivityFeed.svelte';
import QuickActions from '../../components/dashboard/QuickActions.svelte';

const operatingSignals = [
  {
    label: 'Collections',
    value: '4 invoices need follow-up',
    tone: 'warning',
  },
  {
    label: 'Cash position',
    value: 'Healthy for the next 9.4 months',
    tone: 'positive',
  },
  {
    label: 'Margin trend',
    value: 'Improving for the third straight period',
    tone: 'positive',
  },
];
---

<DashboardLayout
  title="Dashboard"
  description="Insight Hunter dashboard with KPI visibility, financial charts, AI insights, and operator actions."
>
  <section class="dashboard-page">
    <section class="hero-panel card-surface">
      <div class="hero-copy">
        <p class="eyebrow">Overview</p>
        <h2>Business dashboard</h2>
        <p class="hero-text">
          Watch revenue, liquidity, margins, and execution risk from one operating view designed to help you move faster than month-end reporting.
        </p>
      </div>

      <div class="hero-actions">
        <a class="upgrade-btn" href="/dashboard/upgrade">Upgrade plan</a>
        <a class="secondary-link" href="/dashboard/reports">Open reports</a>
      </div>
    </section>

    <section class="signal-row" aria-label="Operating signals">
      {operatingSignals.map((signal) => (
        <article class={`signal-chip ${signal.tone}`}>
          <span>{signal.label}</span>
          <strong>{signal.value}</strong>
        </article>
      ))}
    </section>

    <section class="kpi-grid" aria-label="Key performance indicators">
      <KPICard title="Monthly revenue" value="$84,200" delta="+8.4%" />
      <KPICard title="Cash on hand" value="$46,880" delta="+3.2%" />
      <KPICard title="Gross margin" value="58.1%" delta="+1.1%" />
      <KPICard title="Runway" value="9.4 mo" delta="-0.3 mo" />
    </section>

    <section class="chart-grid">
      <article class="panel chart-panel">
        <div class="panel-head">
          <div>
            <p class="panel-kicker">Trend</p>
            <h3>Revenue momentum</h3>
          </div>
          <a href="/dashboard/reports">Details</a>
        </div>
        <RevenueChart client:load />
      </article>

      <article class="panel chart-panel">
        <div class="panel-head">
          <div>
            <p class="panel-kicker">Liquidity</p>
            <h3>Cash flow position</h3>
          </div>
          <a href="/dashboard/forecast">Forecast</a>
        </div>
        <CashFlowChart client:load />
      </article>
    </section>

    <section class="content-grid">
      <article class="panel">
        <div class="panel-head">
          <div>
            <p class="panel-kicker">AI CFO</p>
            <h3>Priority insights</h3>
          </div>
          <a href="/dashboard/insights">View all</a>
        </div>
        <InsightCard client:load />
      </article>

      <article class="panel">
        <div class="panel-head">
          <div>
            <p class="panel-kicker">Recent activity</p>
            <h3>What changed</h3>
          </div>
          <a href="/dashboard/settings">Settings</a>
        </div>
        <ActivityFeed client:load />
      </article>

      <article class="panel wide">
        <div class="panel-head">
          <div>
            <p class="panel-kicker">Execution</p>
            <h3>Next best actions</h3>
          </div>
          <a href="/dashboard/bookkeeping">Open bookkeeping</a>
        </div>
        <QuickActions client:load />
      </article>
    </section>
  </section>
</DashboardLayout>

<style>
  .dashboard-page {
    display: grid;
    gap: 18px;
  }

  .card-surface,
  .panel,
  .signal-chip {
    border: 1px solid var(--app-border);
    border-radius: var(--app-radius-md);
    background:
      linear-gradient(180deg, rgba(19, 29, 44, 0.96), rgba(12, 20, 31, 0.96));
    box-shadow: var(--app-shadow);
  }

  .hero-panel {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    padding: 24px;
  }

  .hero-copy h2 {
    margin: 0 0 12px;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    letter-spacing: -0.03em;
  }

  .hero-text {
    max-width: 760px;
    color: var(--app-muted);
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .upgrade-btn,
  .secondary-link,
  .panel-head a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 14px;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .upgrade-btn {
    background: var(--app-gold);
    color: #10131a;
  }

  .upgrade-btn:hover {
    transform: translateY(-1px);
  }

  .secondary-link,
  .panel-head a {
    border: 1px solid var(--app-border);
    color: var(--app-text);
    background: transparent;
  }

  .secondary-link:hover,
  .panel-head a:hover {
    border-color: var(--app-border-strong);
    color: var(--app-cyan);
  }

  .signal-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .signal-chip {
    padding: 16px 18px;
  }

  .signal-chip span {
    display: block;
    margin-bottom: 6px;
    color: var(--app-subtle);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .signal-chip strong {
    color: var(--app-text);
    font-size: 0.98rem;
    line-height: 1.45;
  }

  .signal-chip.positive {
    border-color: rgba(109, 211, 163, 0.2);
  }

  .signal-chip.warning {
    border-color: rgba(240, 178, 100, 0.24);
  }

  .kpi-grid,
  .chart-grid,
  .content-grid {
    display: grid;
    gap: 16px;
  }

  .kpi-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .chart-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .content-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel {
    padding: 18px;
    min-width: 0;
  }

  .chart-panel {
    min-height: 360px;
  }

  .wide {
    grid-column: 1 / -1;
  }

  .panel-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 16px;
  }

  .panel-kicker,
  .eyebrow {
    margin: 0 0 8px;
    color: var(--app-cyan);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .panel-head h3 {
    font-size: 1.12rem;
    letter-spacing: -0.02em;
  }

  @media (max-width: 1180px) {
    .kpi-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .hero-panel,
    .chart-grid,
    .content-grid,
    .signal-row {
      grid-template-columns: 1fr;
    }

    .hero-panel {
      flex-direction: column;
      align-items: stretch;
    }
  }

  @media (max-width: 640px) {
    .kpi-grid {
      grid-template-columns: 1fr;
    }

    .panel-head {
      flex-direction: column;
      align-items: stretch;
    }

    .upgrade-btn,
    .secondary-link,
    .panel-head a {
      width: 100%;
    }
  }
</style>
