---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Dashboard">
  <section class="container" style="padding:60px 24px">
    <div style="margin-bottom:32px;">
      <h1 style="font-size:1.8rem;color:#fff;margin-bottom:6px;">Good morning ✦</h1>
      <p style="color:#999;font-size:0.95rem;">Here's your financial snapshot.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;">
      <div class="card" style="padding:24px;">
        <div style="color:var(--muted);font-size:0.85rem;margin-bottom:8px;">💰 Monthly Revenue</div>
        <div style="font-family:var(--font-display);font-size:1.75rem;font-weight:700;">$24,800</div>
        <div style="color:#4ade80;font-size:0.8rem;margin-top:4px;">↑ 12% vs last month</div>
      </div>
      <div class="card" style="padding:24px;">
        <div style="color:var(--muted);font-size:0.85rem;margin-bottom:8px;">🏦 Cash on Hand</div>
        <div style="font-family:var(--font-display);font-size:1.75rem;font-weight:700;">$11,240</div>
        <div style="color:#4ade80;font-size:0.8rem;margin-top:4px;">↑ 3% vs last week</div>
      </div>
      <div class="card" style="padding:24px;">
        <div style="color:var(--muted);font-size:0.85rem;margin-bottom:8px;">📉 Expenses (MTD)</div>
        <div style="font-family:var(--font-display);font-size:1.75rem;font-weight:700;">$8,420</div>
        <div style="color:#f87171;font-size:0.8rem;margin-top:4px;">↑ 5% vs last month</div>
      </div>
      <div class="card" style="padding:24px;">
        <div style="color:var(--muted);font-size:0.85rem;margin-bottom:8px;">📄 Open Invoices</div>
        <div style="font-family:var(--font-display);font-size:1.75rem;font-weight:700;">$6,300</div>
        <div style="color:#f87171;font-size:0.8rem;margin-top:4px;">2 overdue</div>
      </div>
    </div>
  </section>
</MarketingLayout>
