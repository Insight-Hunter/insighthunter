---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import KPICard from '../../components/dashboard/KPICard.svelte';
import RevenueChart from '../../components/dashboard/RevenueChart.svelte';
import CashFlowChart from '../../components/dashboard/CashFlowChart.svelte';
import InsightCard from '../../components/dashboard/InsightCard.svelte';
import ActivityFeed from '../../components/dashboard/ActivityFeed.svelte';
import QuickActions from '../../components/dashboard/QuickActions.svelte';
---

<DashboardLayout title="Dashboard">
  <section class="dashboard-page">
    <div class="page-head">
      <div>
        <p class="eyebrow">Overview</p>
        <h1>Business dashboard</h1>
      </div>
      <a href="/dashboard/upgrade">Upgrade</a>
    </div>

    <div class="kpi-grid">
      <KPICard title="Monthly revenue" value="$84,200" delta="+8.4%" />
      <KPICard title="Cash on hand" value="$46,880" delta="+3.2%" />
      <KPICard title="Gross margin" value="58.1%" delta="+1.1%" />
      <KPICard title="Runway" value="9.4 mo" delta="-0.3 mo" />
    </div>

    <div class="chart-grid">
      <div class="panel"><RevenueChart client:load /></div>
      <div class="panel"><CashFlowChart client:load /></div>
    </div>

    <div class="content-grid">
      <div class="panel"><InsightCard client:load /></div>
      <div class="panel"><ActivityFeed client:load /></div>
      <div class="panel wide"><QuickActions client:load /></div>
    </div>
  </section>
</DashboardLayout>

<style>
  .dashboard-page { display: grid; gap: 1rem; }
  .page-head { display: flex; justify-content: space-between; gap: 1rem; align-items: center; }
  .page-head a { padding: .8rem 1rem; border: 1px solid rgba(84,72,56,.18); border-radius: 999px; text-decoration: none; color: inherit; }
  .kpi-grid, .chart-grid, .content-grid { display: grid; gap: 1rem; }
  .kpi-grid { grid-template-columns: repeat(4, 1fr); }
  .chart-grid { grid-template-columns: 1fr 1fr; }
  .content-grid { grid-template-columns: 1fr 1fr; }
  .panel, .wide { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1rem; }
  .wide { grid-column: 1 / -1; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; margin: 0; }
  @media (max-width: 980px) { .kpi-grid, .chart-grid, .content-grid { grid-template-columns: 1fr; } }
</style>
