---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Insight Standard App | Insight Hunter" description="Homepage for Insight Standard.">
  <section class="container section app-home">
    <span class="eyebrow">Insight Standard</span>
    <h1>More structure, stronger visibility.</h1>
    <p>Use this route as the home for Insight Standard and as the primary destination for subdomain-based app traffic.</p>
    <div class="actions">
      <a href="https://auth.insighthunter.app/signup?plan=standard">Start standard</a>
      <a href="/pricing">View plan</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border-radius: 999px; border: 1px solid rgba(84,72,56,.18); text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
