---
// /onboarding — shown after first Access login, before dashboard
// Collects business_name + plan. Redirects to Stripe or /dashboard.
export const prerender = false;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to InsightHunter</title>
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal: #01696f; --teal-hover: #0c4e54;
      --bg: #f7f6f2; --surface: #ffffff;
      --text: #28251d; --muted: #7a7974;
      --border: #d4d1ca; --radius: 0.75rem;
      --font: 'Satoshi', system-ui, sans-serif;
    }
    body { font-family: var(--font); background: var(--bg); color: var(--text);
           min-height: 100dvh; display: flex; align-items: center; justify-content: center;
           padding: 1.5rem; }
    .card { background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); padding: 2.5rem; max-width: 520px;
            width: 100%; box-shadow: 0 4px 24px rgba(0,0,0,.07); }
    .logo { font-size: 1.25rem; font-weight: 700; color: var(--teal); margin-bottom: 2rem; }
    h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem; }
    p.sub { color: var(--muted); margin-bottom: 2rem; font-size: 0.95rem; }
    label { display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.4rem; }
    input, select {
      width: 100%; padding: 0.65rem 0.875rem; border: 1px solid var(--border);
      border-radius: 0.5rem; font-family: inherit; font-size: 1rem;
      background: var(--bg); color: var(--text); margin-bottom: 1.25rem;
      transition: border-color 150ms;
    }
    input:focus, select:focus { outline: none; border-color: var(--teal); }
    .plans { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
    .plan-card { border: 2px solid var(--border); border-radius: 0.625rem; padding: 1rem;
                 cursor: pointer; transition: border-color 150ms; user-select: none; }
    .plan-card:has(input:checked) { border-color: var(--teal); background: #f0fafa; }
    .plan-card input { display: none; }
    .plan-name { font-weight: 700; font-size: 1rem; }
    .plan-price { color: var(--muted); font-size: 0.8rem; margin-top: 0.25rem; }
    .plan-features { font-size: 0.8rem; color: var(--muted); margin-top: 0.5rem; line-height: 1.5; }
    button[type=submit] {
      width: 100%; padding: 0.85rem; background: var(--teal); color: white;
      border: none; border-radius: 0.625rem; font-weight: 600; font-size: 1rem;
      cursor: pointer; transition: background 150ms;
    }
    button[type=submit]:hover { background: var(--teal-hover); }
    button[type=submit]:disabled { opacity: 0.6; cursor: not-allowed; }
    .error { color: #a12c7b; font-size: 0.875rem; margin-top: 0.75rem; display: none; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">InsightHunter</div>
    <h1>Welcome aboard 👋</h1>
    <p class="sub">Let's set up your account. Takes 60 seconds.</p>

    <form id="onboard-form">
      <label for="business_name">Business name</label>
      <input id="business_name" name="business_name" type="text"
             placeholder="Acme Bookkeeping LLC" required autocomplete="organization" />

      <label for="industry">Industry</label>
      <select id="industry" name="industry">
        <option value="">Select industry…</option>
        <option>Accounting &amp; Bookkeeping</option>
        <option>Retail</option>
        <option>Restaurant &amp; Food Service</option>
        <option>Construction</option>
        <option>Healthcare</option>
        <option>Professional Services</option>
        <option>E-commerce</option>
        <option>Non-profit</option>
        <option>Other</option>
      </select>

      <label>Choose your plan</label>
      <div class="plans">
        <label class="plan-card">
          <input type="radio" name="plan" value="free" checked />
          <div class="plan-name">Free</div>
          <div class="plan-price">$0 / mo</div>
          <div class="plan-features">Basic bookkeeping<br/>1 user</div>
        </label>
        <label class="plan-card">
          <input type="radio" name="plan" value="lite" />
          <div class="plan-name">Lite</div>
          <div class="plan-price">$19 / mo</div>
          <div class="plan-features">AI insights<br/>Up to 3 users</div>
        </label>
        <label class="plan-card">
          <input type="radio" name="plan" value="pro" />
          <div class="plan-name">Pro</div>
          <div class="plan-price">$49 / mo</div>
          <div class="plan-features">Payroll + API<br/>Up to 10 users</div>
        </label>
        <label class="plan-card">
          <input type="radio" name="plan" value="enterprise" />
          <div class="plan-name">Enterprise</div>
          <div class="plan-price">$149 / mo</div>
          <div class="plan-features">Multi-entity<br/>Unlimited users</div>
        </label>
      </div>

      <button type="submit" id="submit-btn">Get started →</button>
      <p class="error" id="error-msg"></p>
    </form>
  </div>

  <script>
    const form = document.getElementById('onboard-form');
    const btn = document.getElementById('submit-btn');
    const errMsg = document.getElementById('error-msg');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Saving…';
      errMsg.style.display = 'none';

      const data = Object.fromEntries(new FormData(form));

      try {
        const res = await fetch('/api/onboard', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (!res.ok) {
          throw new Error(result.error || 'Something went wrong');
        }

        window.location.href = result.redirect || '/dashboard';
      } catch (err) {
        errMsg.textContent = err.message;
        errMsg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Get started →';
      }
    });
  </script>
</body>
</html>
