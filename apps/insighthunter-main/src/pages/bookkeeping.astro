---
// src/pages/bookkeeping.astro
// InsightHunter — Bookkeeping Module
// Apple HIG-inspired: clear hierarchy, generous spacing, 44pt touch targets
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Bookkeeping — InsightHunter">
  <div class="bk-root">

    <!-- ── Top Nav Bar ────────────────────────────────────── -->
    <header class="nav-bar">
      <button class="nav-back" aria-label="Back">
        <svg width="10" height="17" viewBox="0 0 10 17" fill="none">
          <path d="M9 1L1.5 8.5L9 16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Financials</span>
      </button>
      <h1 class="nav-title">Bookkeeping</h1>
      <button class="nav-action" aria-label="Add transaction">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M9 1V17M1 9H17" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <!-- ── Period Picker ──────────────────────────────────── -->
    <section class="period-strip" role="tablist" aria-label="Time period">
      <button class="period-btn active" role="tab" aria-selected="true" data-period="month">Month</button>
      <button class="period-btn" role="tab" aria-selected="false" data-period="quarter">Quarter</button>
      <button class="period-btn" role="tab" aria-selected="false" data-period="ytd">YTD</button>
      <button class="period-btn" role="tab" aria-selected="false" data-period="year">Year</button>
      <div class="period-pill" aria-hidden="true"></div>
    </section>

    <main class="bk-scroll">

      <!-- ── P&L Summary Cards ───────────────────────────── -->
      <section class="summary-grid" aria-label="Profit and loss summary">
        <div class="summary-card card--income">
          <span class="card-label">Income</span>
          <span class="card-amount" data-value="84320">$84,320</span>
          <span class="card-delta positive">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 1L9 5H6V9H4V5H1L5 1Z" fill="currentColor"/></svg>
            12.4%
          </span>
        </div>
        <div class="summary-card card--expenses">
          <span class="card-label">Expenses</span>
          <span class="card-amount" data-value="51890">$51,890</span>
          <span class="card-delta negative">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 9L9 5H6V1H4V5H1L5 9Z" fill="currentColor"/></svg>
            3.1%
          </span>
        </div>
        <div class="summary-card card--net full-width">
          <span class="card-label">Net Profit</span>
          <span class="card-amount net-amount">$32,430</span>
          <div class="profit-bar-track" role="presentation">
            <div class="profit-bar-fill" style="width: 38.4%"></div>
          </div>
          <span class="card-margin">38.4% margin</span>
        </div>
      </section>

      <!-- ── Cash Flow Sparkline ────────────────────────── -->
      <section class="chart-section card-glass" aria-label="Cash flow chart">
        <div class="section-header">
          <h2 class="section-title">Cash Flow</h2>
          <span class="section-meta">May 2025</span>
        </div>
        <div class="chart-wrap" aria-hidden="true">
          <svg class="sparkline" viewBox="0 0 320 80" preserveAspectRatio="none">
            <defs>
              <linearGradient id="cashGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#E34E24" stop-opacity="0.35"/>
                <stop offset="100%" stop-color="#E34E24" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <!-- Area fill -->
            <path class="spark-area"
              d="M0,60 C20,55 35,40 60,38 C85,36 100,50 120,42 C140,34 155,20 180,18 C205,16 220,30 245,22 C265,16 285,10 320,8 L320,80 L0,80 Z"
              fill="url(#cashGrad)"/>
            <!-- Line -->
            <path class="spark-line"
              d="M0,60 C20,55 35,40 60,38 C85,36 100,50 120,42 C140,34 155,20 180,18 C205,16 220,30 245,22 C265,16 285,10 320,8"
              fill="none" stroke="#E34E24" stroke-width="2" stroke-linecap="round"/>
            <!-- Current dot -->
            <circle class="spark-dot" cx="320" cy="8" r="4" fill="#E34E24"/>
          </svg>
          <div class="chart-labels" aria-hidden="true">
            <span>May 1</span><span>May 8</span><span>May 15</span><span>May 22</span><span>Today</span>
          </div>
        </div>
      </section>

      <!-- ── Category Breakdown ─────────────────────────── -->
      <section class="categories-section" aria-label="Expense categories">
        <div class="section-header">
          <h2 class="section-title">By Category</h2>
          <button class="see-all-btn">See All</button>
        </div>
        <ul class="category-list" role="list">
          <li class="category-row" role="listitem">
            <span class="cat-icon" style="--hue: 200">🏢</span>
            <div class="cat-info">
              <span class="cat-name">Operations</span>
              <div class="cat-bar-track" role="presentation"><div class="cat-bar-fill" style="width:72%; --accent:#E34E24"></div></div>
            </div>
            <div class="cat-amounts">
              <span class="cat-value">$18,420</span>
              <span class="cat-pct">35.5%</span>
            </div>
          </li>
          <li class="category-row" role="listitem">
            <span class="cat-icon" style="--hue: 160">👥</span>
            <div class="cat-info">
              <span class="cat-name">Payroll</span>
              <div class="cat-bar-track" role="presentation"><div class="cat-bar-fill" style="width:58%; --accent:#6C9CDB"></div></div>
            </div>
            <div class="cat-amounts">
              <span class="cat-value">$15,200</span>
              <span class="cat-pct">29.3%</span>
            </div>
          </li>
          <li class="category-row" role="listitem">
            <span class="cat-icon" style="--hue: 280">💻</span>
            <div class="cat-info">
              <span class="cat-name">Software & Tools</span>
              <div class="cat-bar-track" role="presentation"><div class="cat-bar-fill" style="width:30%; --accent:#A87DD8"></div></div>
            </div>
            <div class="cat-amounts">
              <span class="cat-value">$7,840</span>
              <span class="cat-pct">15.1%</span>
            </div>
          </li>
          <li class="category-row" role="listitem">
            <span class="cat-icon" style="--hue: 20">📦</span>
            <div class="cat-info">
              <span class="cat-name">Inventory</span>
              <div class="cat-bar-track" role="presentation"><div class="cat-bar-fill" style="width:22%; --accent:#E07B4A"></div></div>
            </div>
            <div class="cat-amounts">
              <span class="cat-value">$5,630</span>
              <span class="cat-pct">10.8%</span>
            </div>
          </li>
        </ul>
      </section>

      <!-- ── Recent Transactions ────────────────────────── -->
      <section class="transactions-section" aria-label="Recent transactions">
        <div class="section-header">
          <h2 class="section-title">Recent</h2>
          <button class="see-all-btn">See All</button>
        </div>

        <!-- Search bar -->
        <div class="search-wrap">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 10.5L14 14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input class="search-input" type="search" placeholder="Search transactions…" aria-label="Search transactions"/>
        </div>

        <!-- Filter chips -->
        <div class="filter-chips" role="group" aria-label="Filter by type">
          <button class="chip active" data-filter="all">All</button>
          <button class="chip" data-filter="income">Income</button>
          <button class="chip" data-filter="expense">Expense</button>
          <button class="chip" data-filter="transfer">Transfer</button>
        </div>

        <!-- Transaction list -->
        <ul class="txn-list" role="list" id="txnList">

          <li class="txn-date-header" role="presentation"><span>Today</span></li>

          <li class="txn-row" role="listitem" data-type="income">
            <div class="txn-avatar income-avatar" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 14L9 4L16 14H2Z" fill="currentColor"/></svg>
            </div>
            <div class="txn-body">
              <span class="txn-merchant">Acme Corp — Invoice #1042</span>
              <span class="txn-meta">Accounts Receivable · 11:32 AM</span>
            </div>
            <span class="txn-amount income-amount">+$4,200.00</span>
          </li>

          <li class="txn-row" role="listitem" data-type="expense">
            <div class="txn-avatar expense-avatar" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M6 9H12M9 6V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div class="txn-body">
              <span class="txn-merchant">AWS — Compute Usage</span>
              <span class="txn-meta">Software & Tools · 9:15 AM</span>
            </div>
            <span class="txn-amount expense-amount">−$318.42</span>
          </li>

          <li class="txn-date-header" role="presentation"><span>Yesterday</span></li>

          <li class="txn-row" role="listitem" data-type="expense">
            <div class="txn-avatar expense-avatar" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M9 6V9.5L11 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div class="txn-body">
              <span class="txn-merchant">WeWork — Monthly Desk</span>
              <span class="txn-meta">Operations · 8:00 AM</span>
            </div>
            <span class="txn-amount expense-amount">−$1,200.00</span>
          </li>

          <li class="txn-row" role="listitem" data-type="income">
            <div class="txn-avatar income-avatar" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 14L9 4L16 14H2Z" fill="currentColor"/></svg>
            </div>
            <div class="txn-body">
              <span class="txn-merchant">Beta Co — Retainer</span>
              <span class="txn-meta">Accounts Receivable · 3:44 PM</span>
            </div>
            <span class="txn-amount income-amount">+$6,500.00</span>
          </li>

          <li class="txn-row" role="listitem" data-type="transfer">
            <div class="txn-avatar transfer-avatar" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 6H15M15 6L11 2M15 6L11 10M15 12H3M3 12L7 8M3 12L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="txn-body">
              <span class="txn-merchant">Operating → Savings</span>
              <span class="txn-meta">Internal Transfer · 12:00 PM</span>
            </div>
            <span class="txn-amount transfer-amount">$5,000.00</span>
          </li>

          <li class="txn-date-header" role="presentation"><span>May 16</span></li>

          <li class="txn-row" role="listitem" data-type="expense">
            <div class="txn-avatar expense-avatar" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <div class="txn-body">
              <span class="txn-merchant">Gusto — Payroll Run</span>
              <span class. Persönliche Notizen sind vertraulich und werden nicht mit anderen geteilt.="txn-meta">Payroll · Auto-pay</span>
            </div>
            <span class="txn-amount expense-amount">−$12,800.00</span>
          </li>

        </ul>
      </section>

      <!-- ── AI Insights Banner ─────────────────────────── -->
      <section class="ai-insight-card" aria-label="AI insight">
        <div class="ai-glow" aria-hidden="true"></div>
        <div class="ai-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <path d="M11 2L13.5 8.5L20 11L13.5 13.5L11 20L8.5 13.5L2 11L8.5 8.5L11 2Z" fill="currentColor" opacity="0.9"/>
          </svg>
        </div>
        <div class="ai-content">
          <p class="ai-headline">Spending 18% above forecast</p>
          <p class="ai-body">Software & Tools jumped $1,200 vs. April. Review upcoming Cloudflare and Vercel renewals to avoid surprises this month.</p>
        </div>
        <button class="ai-action" aria-label="View AI recommendation detail">
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1L7 7L1 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </section>

      <!-- bottom safe-area padding -->
      <div class="bottom-pad" aria-hidden="true"></div>
    </main>

    <!-- ── FAB ───────────────────────────────────────────── -->
    <button class="fab" aria-label="Add new transaction">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M10 2V18M2 10H18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

  </div>
</MarketingLayout>

<style>
  /* ── Design tokens ───────────────────────────────────────── */
  :root {
    --navy-900: #080E1A;
    --navy-800: #0D1628;
    --navy-700: #111E35;
    --navy-600: #172340;
    --navy-500: #1E2E50;
    --navy-400: #263660;
    --gold:     #E34E24;
    --gold-dim: rgba(227,78,36,0.18);
    --gold-glow:rgba(227,78,36,0.08);
    --text-primary:   #F0EDE4;
    --text-secondary: #8A95A8;
    --text-tertiary:  #4F5B70;
    --green:  #48C88A;
    --red:    #E05B5B;
    --blue:   #6C9CDB;
    --purple: #A87DD8;
    --orange: #E07B4A;
    --radius-sm:  10px;
    --radius-md:  14px;
    --radius-lg:  20px;
    --radius-xl:  26px;
    --shadow-card: 0 4px 24px rgba(0,0,0,0.5);
    --font-body: 'SF Pro Text', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    --font-display: 'SF Pro Display', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── Root layout ────────────────────────────────────────── */
  .bk-root {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    background: var(--navy-900);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    overflow: hidden;
    max-width: 430px;
    margin: 0 auto;
    position: relative;
  }

  /* ── Navigation bar (Apple HIG large title pattern) ─────── */
  .nav-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: env(safe-area-inset-top, 48px) 16px 12px;
    background: rgba(8,14,26,0.92);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: sticky;
    top: 0;
    z-index: 100;
    min-height: 88px;
  }

  .nav-back {
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    color: var(--gold);
    font-family: var(--font-body);
    font-size: 17px;
    cursor: pointer;
    min-height: 44px;
    min-width: 44px;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-back svg { flex-shrink: 0; }

  .nav-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-align: center;
    color: var(--text-primary);
  }

  .nav-action {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    background: none;
    border: none;
    color: var(--gold);
    cursor: pointer;
    min-height: 44px;
    min-width: 44px;
    -webkit-tap-highlight-color: transparent;
  }

  /* ── Period picker ──────────────────────────────────────── */
  .period-strip {
    position: relative;
    display: flex;
    padding: 12px 16px 0;
    gap: 4px;
    background: var(--navy-900);
  }

  .period-btn {
    flex: 1;
    position: relative;
    z-index: 1;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 4px;
    min-height: 44px;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .period-btn.active { color: var(--text-primary); font-weight: 600; }

  /* ── Scrollable content ─────────────────────────────────── */
  .bk-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    padding: 16px 16px 0;
    scroll-behavior: smooth;
  }
  .bk-scroll::-webkit-scrollbar { display: none; }

  /* ── Summary cards ──────────────────────────────────────── */
  .summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }

  .summary-card {
    background: var(--navy-700);
    border-radius: var(--radius-md);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: var(--shadow-card);
    transition: transform 0.15s ease;
  }
  .summary-card:active { transform: scale(0.97); }
  .full-width { grid-column: 1 / -1; }

  .card-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .card-amount {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.1;
  }

  .net-amount { color: var(--gold); }

  .card-delta {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 12px;
    font-weight: 600;
    margin-top: 2px;
  }
  .positive { color: var(--green); }
  .negative { color: var(--red); }

  .profit-bar-track {
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 99px;
    overflow: hidden;
    margin-top: 8px;
  }
  .profit-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold) 0%, #E8C76A 100%);
    border-radius: 99px;
    animation: barGrow 1s cubic-bezier(0.34,1.56,0.64,1) 0.3s both;
  }
  @keyframes barGrow {
    from { width: 0 !important; }
  }

  .card-margin {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  /* ── Glass card base ────────────────────────────────────── */
  .card-glass {
    background: var(--navy-700);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  /* ── Chart section ──────────────────────────────────────── */
  .chart-section {
    padding: 20px;
    margin-bottom: 16px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .section-meta {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .see-all-btn {
    background: none;
    border: none;
    color: var(--gold);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    min-height: 44px;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .chart-wrap { display: flex; flex-direction: column; gap: 8px; }

  .sparkline {
    width: 100%;
    height: 80px;
    display: block;
  }

  .spark-area { transition: opacity 0.3s; }

  .spark-dot {
    filter: drop-shadow(0 0 6px var(--gold));
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; r: 4; }
    50% { opacity: 0.6; r: 5; }
  }

  .chart-labels {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--text-tertiary);
    padding: 0 2px;
  }

  /* ── Category breakdown ─────────────────────────────────── */
  .categories-section {
    background: var(--navy-700);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-lg);
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: var(--shadow-card);
  }

  .category-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .category-row {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    align-items: center;
    gap: 12px;
  }

  .cat-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--navy-600);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .cat-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .cat-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cat-bar-track {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.08);
    border-radius: 99px;
    overflow: hidden;
  }
  .cat-bar-fill {
    height: 100%;
    background: var(--accent, var(--gold));
    border-radius: 99px;
    animation: barGrow 0.8s cubic-bezier(0.34,1.56,0.64,1) 0.2s both;
  }

  .cat-amounts {
