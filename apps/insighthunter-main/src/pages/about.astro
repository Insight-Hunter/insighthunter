---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Nav from '../components/marketing/Nav.astro';
---
<MarketingLayout title="About">
  <Nav />
  <section style="max-width:760px;margin:0 auto;padding:clamp(60px,6vw,120px) 24px;">
    <h1 style="font-family:var(--font-display);font-size:2.5rem;font-style:italic;margin-bottom:24px;">The Auto-CFO for everyone.</h1>
    <p style="font-size:1rem;color:var(--muted);margin-bottom:16px;">Insight Hunter was founded on the belief that every small business deserves the same financial clarity that Fortune 500 companies pay teams of analysts to produce.</p>
    <p style="font-size:1rem;color:var(--muted);margin-bottom:16px;">We target 65M freelancers and 33M small firms in the U.S. who are underserved by bookkeeping software that stops at transaction data and never translates it into decisions.</p>
    <p style="font-size:1rem;color:var(--muted);">Built on Cloudflare's edge infrastructure, Insight Hunter delivers sub-100ms dashboards globally with enterprise-grade security — at a price any small business can afford.</p>
  </section>
</MarketingLayout>
