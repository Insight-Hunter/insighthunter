---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import CTABanner from '../components/marketing/CTABanner.astro';
---
<MarketingLayout title="About">
  <section style="max-width:var(--content-narrow);margin:0 auto;padding:clamp(var(--space-12),6vw,var(--space-20)) var(--space-6);">
    <h1 style="font-family:var(--font-display);font-size:var(--text-2xl);font-style:italic;margin-bottom:var(--space-5);">The Auto-CFO for everyone.</h1>
    <p style="font-size:var(--text-base);color:var(--color-text-muted);margin-bottom:var(--space-4);">Insight Hunter was founded on the belief that every small business deserves the same financial clarity that Fortune 500 companies pay teams of analysts to produce.</p>
    <p style="font-size:var(--text-base);color:var(--color-text-muted);margin-bottom:var(--space-4);">We target 65M freelancers and 33M small firms in the U.S. who are underserved by bookkeeping software that stops at transaction data and never translates it into decisions.</p>
    <p style="font-size:var(--text-base);color:var(--color-text-muted);">Built on Cloudflare's edge infrastructure, Insight Hunter delivers sub-100ms dashboards globally with enterprise-grade security — at a price any small business can afford.</p>
  </section>
  <CTABanner headline="See what your numbers are telling you." sub="Upload a CSV and get your first AI CFO insight in under 60 seconds." />
</MarketingLayout>
