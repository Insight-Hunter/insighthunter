---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Page Not Found">
  <section style="text-align:center;padding:clamp(80px,10vw,160px) 24px;">
    <p style="font-size:3rem;font-family:var(--font-display);color:var(--muted);">404</p>
    <h1 style="font-family:var(--font-display);font-size:2rem;font-style:italic;margin:16px 0;">This page went dark.</h1>
    <p style="color:var(--muted);max-width:40ch;margin:0 auto 32px;">The page you're looking for doesn't exist or was moved.</p>
    <a href="/" class="btn btn-gold">Go home</a>
  </section>
</MarketingLayout>
