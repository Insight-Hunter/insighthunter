---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Page Not Found">
  <section style="text-align:center;padding:clamp(var(--space-16),10vw,var(--space-24)) var(--space-6);">
    <p style="font-size:var(--text-3xl);font-family:var(--font-display);color:var(--color-text-faint);">404</p>
    <h1 style="font-family:var(--font-display);font-size:var(--text-2xl);font-style:italic;margin:var(--space-3) 0;">This page went dark.</h1>
    <p style="color:var(--color-text-muted);max-width:40ch;margin:0 auto var(--space-8);">The page you're looking for doesn't exist or was moved.</p>
    <a href="/" class="btn btn-primary">Go home</a>
  </section>
</MarketingLayout>
