---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Page not found | Insight Hunter"
  description="The page you requested could not be found."
>
  <section class="container section center">
    <span class="eyebrow">404</span>
    <h1>That page is not here.</h1>
    <p>The route may have moved, the link may be outdated, or the subdomain path may not be mapped yet.</p>
    <div class="actions">
      <a href="/">Go home</a>
      <a href="/features">Browse apps</a>
      <a href="/dashboard">Open dashboard</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 780px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 6rem 0; }
  .center { text-align: center; }
  .actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem; }
  a { display: inline-flex; padding: .85rem 1.1rem; border-radius: 999px; border: 1px solid rgba(84,72,56,.18); text-decoration: none; color: inherit; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
