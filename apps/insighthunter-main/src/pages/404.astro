---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="404 Not Found">
  <div style="text-align:center;padding:var(--space-16);">
    <h1 style="font-family:var(--font-display);font-size:4rem;color:var(--taupe-800);">404</h1>
    <p style="font-size:1.125rem;color:var(--color-text-muted);margin:var(--space-4) 0 var(--space-8);">That page doesn't exist.</p>
    <a href="/" class="btn btn--primary">Go home</a>
  </div>
</MarketingLayout>
