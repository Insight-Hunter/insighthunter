---
import AuthLayout from '../../layouts/AuthLayout.astro';
---

<AuthLayout title="Auth callback">
  <section class="auth-page callback">
    <p class="eyebrow">Authorization</p>
    <h1>Signing you in…</h1>
    <p>Please wait while your session is verified and your workspace is loaded.</p>
  </section>
</AuthLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const redirect = params.get('redirect') || '/dashboard';
  window.location.replace(redirect);
</script>

<style>
  .callback { text-align: center; padding: 4rem 0; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
