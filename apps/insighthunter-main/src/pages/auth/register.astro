---
import AuthLayout from '../../layouts/AuthLayout.astro';
import RegisterForm from '../../components/auth/RegisterForm.svelte';
---

<AuthLayout title="Register">
  <section class="auth-page">
    <div class="auth-copy">
      <p class="eyebrow">Register</p>
      <h1>Create your Insight Hunter account.</h1>
      <p>Start with one app, then expand into reporting, operations, and finance tools as needed.</p>
    </div>
    <div class="auth-panel">
      <RegisterForm client:load />
    </div>
  </section>
</AuthLayout>

<style>
  .auth-page { display: grid; gap: 1.25rem; grid-template-columns: .95fr 1.05fr; align-items: start; }
  .auth-panel { border: 1px solid rgba(84,72,56,.14); border-radius: 18px; padding: 1.25rem; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
  @media (max-width: 860px) { .auth-page { grid-template-columns: 1fr; } }
</style>
