---
import AuthLayout from '../../layouts/AuthLayout.astro';
import LoginForm from '../../components/auth/LoginForm.svelte';
// FIX: was bare <html> with no AuthLayout — inconsistent vs all other auth pages.
---

<AuthLayout title="Sign In | Insight Hunter">
  <section class="auth-page">
    <div class="auth-card">
      <div class="auth-header">
        <h1>Welcome back</h1>
        <p>Sign in to your Insight Hunter account</p>
      </div>

      <div id="registered-banner" class="success-banner" style="display:none">
        ✅ Account created! Sign in to get started.
      </div>

      <LoginForm client:load />

      <div class="auth-footer">
        <a href="/auth/forgot-password">Forgot password?</a>
        <span>·</span>
        <a href="/auth/register">Create account</a>
      </div>
    </div>
  </section>
</AuthLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('registered') === '1') {
    const banner = document.getElementById('registered-banner');
    if (banner) banner.style.display = 'block';
  }
</script>

<style>
  .auth-page { display:flex; justify-content:center; align-items:center; min-height:60vh; padding:2rem 1rem; }
  .auth-card { width:100%; max-width:400px; display:flex; flex-direction:column; gap:1.5rem; }
  .auth-header h1 { font-size:1.6rem; margin-bottom:0.25rem; }
  .auth-header p { color:var(--muted); font-size:0.9rem; }
  .success-banner { background:rgba(63,207,142,0.12); border:1px solid rgba(63,207,142,0.3); color:#3FCF8E; padding:10px 14px; border-radius:8px; font-size:0.875rem; }
  .auth-footer { display:flex; gap:8px; justify-content:center; font-size:0.85rem; color:var(--muted); }
  .auth-footer a { color:var(--muted); text-decoration:underline; }
  .auth-footer a:hover { color:var(--white); }
</style>
