---
import AuthLayout from '../../layouts/AuthLayout.astro';
import LoginForm from '../../components/auth/LoginForm.svelte';
---

<AuthLayout title="Sign In | Insight Hunter">
  <section class="auth-page">
    <div class="auth-card">
      <div class="auth-header">
        <h1>Welcome back</h1>
        <p>Sign in to your Insight Hunter account</p>
      </div>

      <!-- Success: arrived from registration -->
      <div id="registered-banner" class="notice-banner notice-success" style="display:none">
        ✅ Account created! Sign in to get started.
      </div>

      <!-- Info: arrived from logout -->
      <div id="logged-out-banner" class="notice-banner notice-info" style="display:none">
        👋 You've been signed out successfully.
      </div>

      <LoginForm client:load />

      <div class="auth-footer">
        <a href="/auth/forgot-password">Forgot password?</a>
        <span>·</span>
        <a href="/auth/register">Create account</a>
      </div>
    </div>
  </section>
</AuthLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('registered') === '1') {
    const el = document.getElementById('registered-banner');
    if (el) el.style.display = 'block';
  }
  if (params.get('logged_out') === '1') {
    const el = document.getElementById('logged-out-banner');
    if (el) el.style.display = 'block';
  }
</script>

<style>
  .auth-page { display:flex; justify-content:center; align-items:center; min-height:60vh; padding:2rem 1rem; }
  .auth-card { width:100%; max-width:400px; display:flex; flex-direction:column; gap:1.5rem; }
  .auth-header h1 { font-size:1.6rem; margin-bottom:0.25rem; }
  .auth-header p { color:var(--muted); font-size:0.9rem; }
  .notice-banner { padding:10px 14px; border-radius:8px; font-size:0.875rem; border:1px solid; }
  .notice-success { background:rgba(63,207,142,0.12); border-color:rgba(63,207,142,0.3); color:#3FCF8E; }
  .notice-info { background:rgba(94,212,255,0.10); border-color:rgba(94,212,255,0.25); color:#5ED4FF; }
  .auth-footer { display:flex; gap:8px; justify-content:center; font-size:0.85rem; color:var(--muted); }
  .auth-footer a { color:var(--muted); text-decoration:underline; }
  .auth-footer a:hover { color:var(--white); }
</style>
