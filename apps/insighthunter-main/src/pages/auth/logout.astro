---
export const prerender = false;
// Clear the HttpOnly session cookie server-side
Astro.cookies.delete('ih_session', { path: '/' });
---

<!-- FIX 1: wrapped in AuthLayout for consistent branding (was bare <html>) -->
<!-- FIX 2: removed localStorage.removeItem('ih_access_token') — tokens live in HttpOnly cookies only, not localStorage -->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url=/auth/login?logged_out=1" />
    <title>Signing out… | Insight Hunter</title>
  </head>
  <body>
    <script>
      // No localStorage access — auth tokens are HttpOnly cookies set by auth.insighthunter.app
      // The server-side Astro.cookies.delete above handles session invalidation
      window.location.replace('/auth/login?logged_out=1');
    </script>
    <p style="font-family:sans-serif;text-align:center;padding:4rem;color:#888">Signing you out…</p>
  </body>
</html>
