---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Website Services App | Insight Hunter" description="Homepage for Website Services.">
  <section class="container section app-home">
    <span class="eyebrow">Website Services</span>
    <h1>Web support tied to business outcomes.</h1>
    <p>This route is the main homepage for website services and supports direct subdomain-based arrival cleanly.</p>
    <div class="actions">
      <a href="/contact">Request a website plan</a>
      <a href="/features/website-services">Read feature details</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .container { max-width: 980px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .actions a { padding: .85rem 1.1rem; border-radius: 999px; border: 1px solid rgba(84,72,56,.18); text-decoration: none; }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .7; }
</style>
