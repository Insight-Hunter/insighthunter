---
/**
 * HeroSlideshow.astro
 * Drop into: src/components/marketing/HeroSlideshow.astro
 *
 * 4-slide hero carousel that replaces the static Hero.astro.
 * Slide 1: "The full feature stack for your business" (new)
 * Slide 2: Enterprise Speed / Edge Delivered (preserved)
 * Slide 3: Always Know Where You Stand (preserved)
 * Slide 4: Platform overview grid (preserved)
 *
 * No external dependencies — vanilla JS, scoped <style>.
 */
---

<section class="hero-slideshow" id="heroSlideshow" aria-label="Hero slideshow">

  <!-- ══════════════════════════════════════════
       SLIDE 1 — The Full Feature Stack (NEW)
       Replaces: "Stop Flying Blind. Know Your Numbers."
  ══════════════════════════════════════════ -->
  <div class="hero-slide slide-feature-stack active" data-slide="0" role="group" aria-label="Slide 1 of 4">
