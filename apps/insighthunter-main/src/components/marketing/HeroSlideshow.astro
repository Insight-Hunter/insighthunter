  <!-- ── Controls ── -->
  <button class="slide-arrow slide-arrow-prev" id="slidePrev" aria-label="Previous slide">&#8249;</button>
  <button class="slide-arrow slide-arrow-next" id="slideNext" aria-label="Next slide">&#8250;</button>

  <div class="slideshow-dots" role="tablist" aria-label="Slide navigation">
    <button class="slide-dot active" data-target="0" role="tab" aria-selected="true"  aria-label="Go to slide 1"></button>
    <button class="slide-dot"        data-target="1" role="tab" aria-selected="false" aria-label="Go to slide 2"></button>
    <button class="slide-dot"        data-target="2" role="tab" aria-selected="false" aria-label="Go to slide 3"></button>
    <button class="slide-dot"        data-target="3" role="tab" aria-selected="false" aria-label="Go to slide 4"></button>
  </div>
</section>

<!-- ════════════════════════════════════════════
     STYLES — scoped, no Tailwind needed
════════════════════════════════════════════ -->
<style>
/* ── Slideshow shell ── */
.hero-slideshow {
  position: relative;
  overflow: hidden;
  /* min-height drives each slide */
}

/* ── Slide base ── */
.hero-slide {
  display: none; /* JS adds .active to show */
  align-items: center;
  justify-content: center;
  padding: 80px 24px 100px; /* bottom room for dots */
  text-align: center;
  animation: slideIn 0.55s ease both;
}
.hero-slide.active {
  display: flex;
}
@keyframes slideIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Slide backgrounds ── */
.slide-feature-stack {
  background:
    radial-gradient(ellipse 90% 55% at 50% -5%, rgba(227,78,36,0.13) 0%, transparent 60%),
    linear-gradient(180deg, var(--bg-navy, #141522) 0%, var(--bg, #0d0d0d) 100%);
  min-height: 92vh;
}
.slide-edge {
  background:
    radial-gradient(ellipse 70% 50% at 50% 10%, rgba(227,78,36,0.07) 0%, transparent 60%),
    var(--bg-navy, #141522);
  min-height: 92vh;
}
.slide-ai {
  background:
    radial-gradient(ellipse 60% 45% at 60% 20%, rgba(227,78,36,0.09) 0%, transparent 55%),
    var(--bg, #0d0d0d);
  min-height: 92vh;
}
.slide-platform {
  background:
    radial-gradient(ellipse 80% 50% at 30% 50%, rgba(227,78,36,0.06) 0%, transparent 55%),
    var(--bg-navy, #141522);
  min-height: 100vh;
  padding-top: 60px;
  padding-bottom: 80px;
}

/* ── Inner containers ── */
.hero-inner {
  max-width: 820px;
  width: 100%;
  margin: 0 auto;
}
.hero-inner--wide {
  max-width: 1060px;
}

/* ── Typography ── */
.hero-eyebrow {
  display: inline-block;
  color: var(--gold, #E34E24);
  font-size: 12px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  margin-bottom: 20px; padding: 6px 16px;
  border: 1px solid rgba(227,78,36,0.25);
  border-radius: 100px;
}
.slide-context-label {
  display: block;
  font-size: 12px; color: var(--muted, #999);
  letter-spacing: 0.1em; text-transform: uppercase;
  margin-bottom: 12px;
}
h1 {
  font-size: clamp(2.4rem, 6vw, 4.4rem);
  line-height: 1.1; margin-bottom: 20px;
  color: var(--white, #fff);
}
h1 em  { color: var(--gold, #E34E24); font-style: italic; }
h1 strong { color: var(--gold, #E34E24); }
.hero-sub {
  font-size: 1.08rem; color: var(--muted, #999);
  max-width: 620px; margin: 0 auto 32px; line-height: 1.7;
}
.hero-subline {
  font-size: 12px; color: var(--muted, #999);
  margin-top: 16px;
}

/* ── CTA buttons ── */
.hero-actions {
  display: flex; gap: 12px; justify-content: center;
  flex-wrap: wrap; margin-bottom: 12px;
}
.btn-primary-hero {
  background: var(--gold, #E34E24); color: #000;
  font-weight: 700; padding: 14px 28px;
  border-radius: 8px; font-size: 1rem;
  transition: opacity 0.2s; display: inline-block;
}
.btn-primary-hero:hover { opacity: 0.88; }
.btn-ghost-hero {
  border: 1px solid rgba(255,255,255,0.2);
  color: var(--white, #fff); padding: 14px 28px;
  border-radius: 8px; font-size: 1rem;
  transition: border-color 0.2s, color 0.2s; display: inline-block;
}
.btn-ghost-hero:hover { border-color: var(--gold, #E34E24); color: var(--gold, #E34E24); }

/* ── Slide 1: Feature stack pills ── */
.feature-stack-grid {
  display: flex; flex-wrap: wrap; gap: 10px;
  justify-content: center; margin: 0 auto 36px;
  max-width: 700px;
}
.fs-pill {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 8px 16px; border-radius: 100px;
  background: rgba(227,78,36,0.07);
  border: 1px solid rgba(227,78,36,0.25);
  font-size: 0.82rem; font-weight: 600;
  color: var(--white, #fff); white-space: nowrap;
}
.fs-pill-icon { font-size: 0.9rem; }

/* ── Slide 2: Edge grid ── */
.edge-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 12px; max-width: 780px; margin: 0 auto 32px;
}
.edge-pill {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px; padding: 14px 16px;
  text-align: left; display: flex; flex-direction: column; gap: 4px;
}
.ep-icon { font-size: 1.2rem; }
.ep-name { font-weight: 700; font-size: 0.82rem; color: var(--white, #fff); }
.ep-desc { font-size: 0.75rem; color: var(--muted, #999); }
.edge-badges {
  display: flex; gap: 10px; justify-content: center;
  flex-wrap: wrap; margin-top: 12px;
}
.edge-badges span {
  font-size: 12px; color: var(--muted, #999);
  padding: 4px 10px; border: 1px solid #333; border-radius: 4px;
}

/* ── Slide 3: AI stats ── */
.ai-stats {
  display: flex; justify-content: center; flex-wrap: wrap;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px; overflow: hidden;
  max-width: 620px; margin: 0 auto 32px;
}
.ai-stat {
  flex: 1; min-width: 120px;
  padding: 20px 16px; text-align: center;
  border-right: 1px solid rgba(255,255,255,0.07);
}
.ai-stat:last-child { border-right: none; }
.ai-stat-val {
  display: block; font-family: var(--font-display, sans-serif);
  font-size: 2rem; font-weight: 700;
  color: var(--gold, #E34E24); line-height: 1;
}
.ai-stat-lbl { font-size: 0.75rem; color: var(--muted, #999); margin-top: 4px; display: block; }

/* ── Slide 4: Platform mini grid ── */
.platform-mini-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
  gap: 14px; margin-top: 8px;
}
.pmg-card {
  background: var(--card, #1c1b19);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px; padding: 18px;
  text-align: left; display: flex; flex-direction: column; gap: 4px;
  transition: border-color 0.2s;
}
.pmg-card:hover { border-color: rgba(227,78,36,0.25); }
.pmg-icon { font-size: 1.3rem; }
.pmg-name { font-weight: 700; font-size: 0.9rem; color: var(--white, #fff); }
.pmg-tier {
  font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--gold, #E34E24);
}
.pmg-desc { font-size: 0.78rem; color: var(--muted, #999); line-height: 1.5; margin-top: 4px; }

/* ── Navigation arrows ── */
.slide-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  color: var(--white, #fff); font-size: 1.2rem;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 10; transition: background 0.2s;
}
.slide-arrow:hover { background: rgba(255,255,255,0.14); }
.slide-arrow-prev { left: 16px; }
.slide-arrow-next { right: 16px; }

/* ── Dot navigation ── */
.slideshow-dots {
  position: absolute; bottom: 24px; left: 0; right: 0;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  z-index: 10;
}
.slide-dot {
  width: 8px; height: 8px; border-radius: 100px;
  background: rgba(255,255,255,0.25);
  border: none; cursor: pointer;
  transition: background 0.25s, width 0.25s; padding: 0;
}
.slide-dot.active {
  background: var(--gold, #E34E24);
  width: 24px;
}

/* ── Responsive ── */
@media (max-width: 600px) {
  .slide-arrow { display: none; }
  .hero-sub { font-size: 0.97rem; }
  .ai-stats { flex-direction: column; }
  .ai-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .ai-stat:last-child { border-bottom: none; }
}
</style>

<!-- ════════════════════════════════════════════
     SCRIPT — vanilla JS, no framework needed
════════════════════════════════════════════ -->
<script>
(function () {
  const INTERVAL = 6000;
  const slides   = /** @type {NodeListOf<HTMLElement>} */ (document.querySelectorAll('.hero-slide'));
  const dots     = /** @type {NodeListOf<HTMLButtonElement>} */ (document.querySelectorAll('.slide-dot'));
  const root     = /** @type {HTMLElement} */ (document.getElementById('heroSlideshow'));
  let current    = 0;
  let timer      = /** @type {ReturnType<typeof setInterval>|null} */ (null);

  function goTo(/** @type {number} */ n) {
    const total = slides.length;
    const next  = ((n % total) + total) % total;

    // Remove active from current
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    dots[current].setAttribute('aria-selected', 'false');

    current = next;

    // Add active to next
    slides[current].classList.add('active');
    dots[current].classList.add('active');
    dots[current].setAttribute('aria-selected', 'true');

    resetTimer();
  }

  function resetTimer() {
    if (timer) clearInterval(timer);
    timer = setInterval(() => goTo(current + 1), INTERVAL);
  }

  // Arrow buttons
  document.getElementById('slidePrev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('slideNext')?.addEventListener('click', () => goTo(current + 1));

  // Dot buttons
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const target = Number(dot.dataset.target);
      if (!isNaN(target)) goTo(target);
    });
  });

  // Pause on hover / focus
  root?.addEventListener('mouseenter', () => { if (timer) clearInterval(timer); });
  root?.addEventListener('mouseleave', resetTimer);
  root?.addEventListener('focusin',    () => { if (timer) clearInterval(timer); });
  root?.addEventListener('focusout',   resetTimer);

  // Swipe on mobile
  let touchStartX = 0;
  root?.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  root?.addEventListener('touchend',   e => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  // Keyboard navigation
  root?.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });

  // Start
  resetTimer();
})();
</script>
