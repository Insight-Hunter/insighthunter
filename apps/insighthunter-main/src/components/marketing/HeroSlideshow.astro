      <div class="ai-stats">
        <div class="ai-stat"><span class="ai-stat-val">&lt;2s</span><span class="ai-stat-lbl">AI response time</span></div>
        <div class="ai-stat"><span class="ai-stat-val">12mo</span><span class="ai-stat-lbl">Rolling cash forecast</span></div>
        <div class="ai-stat"><span class="ai-stat-val">24/7</span><span class="ai-stat-lbl">Always-on advisor</span></div>
