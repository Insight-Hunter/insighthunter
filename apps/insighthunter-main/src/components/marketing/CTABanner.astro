<section class="cta-banner">
  <div class="cta-inner">
    <h2>Ready to know your numbers?</h2>
    <p>Join thousands of small businesses running smarter with Insight Hunter.</p>
    <a href="https://auth.insighthunter.app/register" class="cta-btn">Start Free — No Card Required</a>
  </div>
</section>

<style>
.cta-banner {
  padding: 80px 24px;
  background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(201,168,76,0.12) 0%, transparent 70%),
              var(--bg);
  text-align: center;
}
.cta-inner { max-width: 600px; margin: 0 auto; }
h2 { font-size: 2rem; margin-bottom: 16px; }
p { color: var(--muted); margin-bottom: 32px; font-size: 1.05rem; }
.cta-btn {
  display: inline-block;
  background: var(--gold);
  color: #000;
  font-weight: 700;
  padding: 16px 36px;
  border-radius: 8px;
  font-size: 1rem;
  transition: opacity 0.2s;
}
.cta-btn:hover { opacity: 0.88; }
</style>
