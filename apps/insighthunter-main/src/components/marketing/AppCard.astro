---
export interface Props {
  name: string;
  tier: string;
  description: string;
  href: string;
  icon: string; // SVG string
}
const { name, tier, description, href, icon } = Astro.props;
---
<a href={href} class="app-card">
  <div class="app-card-icon" set:html={icon} />
  <div class="app-card-body">
    <p class="app-card-name">{name}</p>
    <p class="app-card-tier">{tier}</p>
    <p class="app-card-desc">{description}</p>
  </div>
  <span class="app-card-cta">Learn more →</span>
</a>

<style>
.app-card {
  display: flex;
  flex-direction: column;
  gap: 16px;
  background: var(--card, #1c1b19);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
  padding: 28px;
  transition: border-color 0.2s, transform 0.2s;
  cursor: pointer;
}
.app-card:hover {
  border-color: rgba(227,78,36,0.4);
  transform: translateY(-2px);
}
.app-card-icon { width: 40px; height: 40px; }
.app-card-name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--white);
}
.app-card-tier {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.app-card-desc {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.6;
}
.app-card-cta {
  font-size: 0.85rem;
  color: var(--gold);
  font-weight: 600;
  margin-top: auto;
}
</style>
