import type { Env } from '../types';

/**
 * Called when a formation case reaches COMPLETE status.
 * Seeds the default Chart of Accounts in the bookkeeping worker.
 */
export async function seedBookkeepingCoA(
  orgId: string,
  env: Env
): Promise<void> {
  const res = await fetch(`${env.BOOKKEEPING_WORKER_URL}/seed`, {
    method: 'POST',
    headers: {
      'X-Internal-Secret': env.JWT_SECRET,
      'X-Org-Id': orgId,
      'Content-Type': 'application/json',
    },
  });

  if (!res.ok) {
    const err = await res.text();
    console.error('[BookkeepingHandoff] Seed failed', { orgId, status: res.status, err });
    // Non-fatal — formation is still complete, operator can re-seed
    return;
  }

  const data = await res.json<{ seeded: boolean; count?: number }>();
  console.log('[BookkeepingHandoff] CoA seed result', { orgId, ...data });
}
