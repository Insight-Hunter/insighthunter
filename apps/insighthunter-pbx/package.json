{
  "name": "insight-hunter-pbx",
  "version": "1.0.0",
  "private": true,
  "description": "Insight Hunter PBX — Cloudflare Workers cloud phone system",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "db:init": "wrangler d1 execute PBX_DB --file=src/db/schema.sql",
    "db:init:remote": "wrangler d1 execute PBX_DB --remote --file=src/db/schema.sql",
    "types": "wrangler types",
    "test": "vitest run",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.99.0"
  }
}
